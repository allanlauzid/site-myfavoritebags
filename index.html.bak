<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Favorite Bags — Recife</title>
<meta name="description" content="Bolsas premium selecionadas para mulheres que sabem o que querem. Recife, PE.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>

/* ─── TOKENS ──────────────────────────────────────────────────────────────── */
:root {
  --rose:        #B68B73;
  --rose-dark:   #915E48;
  --rose-deep:   #653C2B;
  --bg:          #F3EFE9;
  --bg2:         #E7E2D9;
  --white:       #FFFFFF;
  --text:        #653C2B;   /* headings */
  --text-mid:    #8C6555;   /* subheadings */
  --text-body:   #7A6055;   /* body */
  --text-muted:  #AE9888;   /* captions */
  --line:        rgba(182,139,115,.18);
  --ease:        cubic-bezier(.4,0,.2,1);
}

/* ─── RESET ───────────────────────────────────────────────────────────────── */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; -webkit-text-size-adjust:100%; }
body { font-family:'Jost',sans-serif; background:var(--bg); color:var(--text-body); overflow-x:hidden; cursor:none; }
a { text-decoration:none; color:inherit; }
button { font-family:'Jost',sans-serif; }

/* ─── CUSTOM CURSOR ───────────────────────────────────────────────────────── */
.cursor {
  position:fixed; width:7px; height:7px;
  background:var(--rose); border-radius:50%;
  pointer-events:none; z-index:9999;
  transform:translate(-50%,-50%);
  transition:width .3s var(--ease), height .3s var(--ease), background .3s;
}
.cursor-ring {
  position:fixed; width:30px; height:30px;
  border:1px solid var(--rose); border-radius:50%;
  pointer-events:none; z-index:9998;
  transform:translate(-50%,-50%); opacity:.45;
  transition:width .45s var(--ease), height .45s var(--ease), opacity .3s;
}
.cursor.h { width:5px; height:5px; background:var(--rose-deep); }
.cursor-ring.h { width:44px; height:44px; opacity:.18; }

/* ─── NAV ─────────────────────────────────────────────────────────────────── */
nav {
  position:fixed; top:0; left:0; right:0; z-index:200;
  padding:28px 64px;
  display:flex; align-items:center; justify-content:space-between;
  transition:background .5s, padding .4s, border-color .5s;
}
nav.s {
  background:rgba(243,239,233,.95);
  backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);
  padding:16px 64px;
  border-bottom:1px solid var(--line);
}
/* Logo */
.nav-logo { display:flex; align-items:center; gap:14px; }
.nav-mono { width:38px; height:38px; flex-shrink:0; }
.nav-words { display:flex; flex-direction:column; gap:1px; }
.nav-words-main {
  font-family:'Cormorant Garamond',serif;
  font-size:15px; font-weight:500;
  letter-spacing:.2em; text-transform:uppercase;
  color:#fff; transition:color .4s; line-height:1;
}
.nav-words-sub {
  font-size:8px; letter-spacing:.38em; text-transform:uppercase;
  color:rgba(255,255,255,.6); transition:color .4s;
}
nav.s .nav-words-main { color:var(--text); }
nav.s .nav-words-sub  { color:var(--text-muted); }

/* Links */
.nav-links { display:flex; gap:40px; list-style:none; }
.nav-links a {
  font-size:10px; letter-spacing:.24em; text-transform:uppercase;
  color:rgba(255,255,255,.72); font-weight:400;
  transition:color .3s; position:relative;
}
.nav-links a::after {
  content:''; position:absolute; bottom:-4px; left:0; right:100%;
  height:1px; background:var(--rose);
  transition:right .4s var(--ease);
}
.nav-links a:hover { color:#fff; }
.nav-links a:hover::after { right:0; }
nav.s .nav-links a { color:var(--text-muted); }
nav.s .nav-links a:hover { color:var(--text); }

/* CTA button */
.nav-cta {
  font-size:10px; letter-spacing:.2em; text-transform:uppercase;
  color:var(--rose); border:1px solid rgba(182,139,115,.5);
  padding:10px 24px; font-weight:400;
  transition:background .3s, color .3s, border-color .3s;
  white-space:nowrap;
}
.nav-cta:hover { background:var(--rose-dark); color:#fff; border-color:var(--rose-dark); }

/* ─── HERO ─────────────────────────────────────────────────────────────────── */
.hero {
  position:relative; height:100vh; min-height:600px;
  overflow:hidden;
  background:var(--rose-deep);
}
/* Slides */
.hero-slide {
  position:absolute; inset:0; opacity:0;
  transition:opacity 1.8s var(--ease);
  will-change:opacity;
}
.hero-slide.active { opacity:1; }

/* Clean dark warm tones — no heavy gradients */
.hs1 { background:linear-gradient(160deg, #3E2318 0%, #2A1610 100%); }
.hs2 { background:linear-gradient(160deg, #2C1A10 0%, #1E1009 100%); }
.hs3 { background:linear-gradient(160deg, #341E12 0%, #231309 100%); }
.hs4 { background:linear-gradient(160deg, #2E1B10 0%, #200F08 100%); }

/* Subtle texture — thin diagonal lines, very low opacity */
.hs-tex {
  position:absolute; inset:0;
  background-image:repeating-linear-gradient(
    135deg,
    transparent 0px, transparent 28px,
    rgba(182,139,115,.03) 28px, rgba(182,139,115,.03) 29px
  );
}

.hero-veil {
  position:absolute; inset:0;
  background:linear-gradient(100deg,
    rgba(30,16,9,.80) 0%,
    rgba(30,16,9,.42) 45%,
    rgba(30,16,9,.06) 100%);
}
.hero-fade-bottom {
  position:absolute; bottom:0; left:0; right:0; height:280px;
  background:linear-gradient(to top, var(--bg), transparent);
  pointer-events:none;
}

/* Right decorative bag silhouette */
.hero-deco {
  position:absolute; right:5%; top:50%; transform:translateY(-50%);
  width:280px; height:320px; opacity:.08;
  pointer-events:none;
}

/* ─── MY FAVORITE MATCH — botão flutuante animado e arrastável ────────── */
@keyframes matchFloat {
  0%, 100% { transform:translateY(0) rotate(-2deg); }
  50%      { transform:translateY(-14px) rotate(2deg); }
}
@keyframes matchGlow {
  0%, 100% { filter:drop-shadow(0 8px 20px rgba(139,74,60,.32)); }
  50%      { filter:drop-shadow(0 14px 28px rgba(139,74,60,.42)); }
}
#matchHeroBtn {
  position:fixed; z-index:250;
  right:6%; top:22%;
  width:92px; height:92px;
  display:flex; align-items:center; justify-content:center;
  cursor:grab; text-decoration:none;
  touch-action:none;
  animation:matchFloat 4.2s ease-in-out infinite, matchGlow 3.2s ease-in-out infinite;
  transition:transform .3s var(--ease, ease);
}
#matchHeroBtn.dragging { cursor:grabbing; animation:none; transition:none; }
#matchHeroBtn:hover { transform:scale(1.08); }
#matchHeroBtn img { width:100%; height:100%; object-fit:contain; display:block; pointer-events:none; -webkit-user-drag:none; }
#matchHeroBtn .mhb-tip {
  position:absolute; top:100%; left:50%; transform:translateX(-50%);
  margin-top:8px; white-space:nowrap;
  font-family:'Jost',sans-serif; font-size:9px; letter-spacing:.16em; text-transform:uppercase;
  color:#fff; background:rgba(36,24,18,.72); padding:5px 12px; border-radius:999px;
  opacity:0; pointer-events:none; transition:opacity .3s;
}
#matchHeroBtn:hover .mhb-tip { opacity:1; }
@media(prefers-reduced-motion:reduce) {
  #matchHeroBtn { animation:none; }
}
@media(max-width:768px) {
  #matchHeroBtn { width:68px; height:68px; }
}

/* Content */
.hero-content {
  position:absolute; left:7%; top:50%; transform:translateY(-50%);
  max-width:560px;
}
.hero-eyebrow {
  display:flex; align-items:center; gap:14px;
  font-size:9px; letter-spacing:.44em; text-transform:uppercase;
  color:var(--rose); margin-bottom:20px;
  opacity:0; animation:fadeUp 1s .2s var(--ease) forwards;
}
.hero-eyebrow::before {
  content:''; display:inline-block;
  width:28px; height:1px; background:var(--rose);
}
/* Inline logo in hero */
.hero-logo {
  width:80px; height:80px; margin-bottom:18px;
  opacity:0; animation:fadeUp 1s .35s var(--ease) forwards;
}
.hero-title {
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(52px,6.2vw,86px);
  font-weight:300; line-height:.96;
  color:#fff; margin-bottom:24px;
  opacity:0; animation:fadeUp 1s .5s var(--ease) forwards;
}
.hero-title em { font-style:italic; color:var(--rose); display:block; margin:0; line-height:1.1; padding:16px 0; }
.hero-sub {
  font-size:13px; letter-spacing:.04em; line-height:1.85;
  color:rgba(255,255,255,.55); font-weight:300;
  margin-bottom:44px; max-width:360px;
  opacity:0; animation:fadeUp 1s .7s var(--ease) forwards;
}
.hero-btn {
  display:inline-flex; align-items:center; gap:16px;
  font-size:10px; letter-spacing:.26em; text-transform:uppercase;
  color:#fff; opacity:0; animation:fadeUp 1s .9s var(--ease) forwards;
  transition:color .3s;
}
.hero-btn:hover { color:var(--rose); }
.hero-btn-line {
  width:40px; height:1px; background:var(--rose);
  transition:width .4s var(--ease);
}
.hero-btn:hover .hero-btn-line { width:68px; }

/* Indicators */
.h-dots {
  position:absolute; bottom:46px; left:50%; transform:translateX(-50%);
  display:flex; gap:8px; z-index:10;
}
.h-dot {
  width:20px; height:1.5px;
  background:rgba(255,255,255,.22); cursor:pointer;
  transition:width .4s, background .4s; position:relative; overflow:hidden;
}
.h-dot.on { width:42px; background:rgba(255,255,255,.14); }
.h-dot.on::after {
  content:''; position:absolute; left:0; top:0;
  height:1.5px; background:var(--rose);
  animation:prog 5s linear;
}
@keyframes prog { from{width:0} to{width:100%} }

/* Scroll hint */
.h-scroll {
  position:absolute; right:46px; bottom:36px;
  display:flex; flex-direction:column; align-items:center; gap:9px;
  opacity:0; animation:fadeIn 1s 1.8s forwards;
}
.h-scroll-txt {
  font-size:8px; letter-spacing:.34em; text-transform:uppercase;
  color:rgba(255,255,255,.3); writing-mode:vertical-rl;
}
.h-scroll-line {
  width:1px; height:42px;
  background:linear-gradient(to bottom, var(--rose), transparent);
  animation:sp 2.4s ease-in-out infinite;
}
@keyframes sp { 0%,100%{opacity:1;transform:scaleY(1)} 50%{opacity:.3;transform:scaleY(.5)} }

/* ─── MARQUEE ─────────────────────────────────────────────────────────────── */
.marquee-strip { background:var(--rose-deep); padding:14px 0; overflow:hidden; }
.m-track { display:flex; white-space:nowrap; animation:mq 26s linear infinite; }
.m-item {
  font-size:9px; letter-spacing:.36em; text-transform:uppercase;
  color:rgba(255,255,255,.55); padding:0 36px; flex-shrink:0;
}
.m-sep { color:var(--rose); opacity:.7; }
@keyframes mq { from{transform:translateX(0)} to{transform:translateX(-50%)} }

/* ─── SHARED SECTION TOKENS ───────────────────────────────────────────────── */
.eyebrow {
  font-size:9px; letter-spacing:.42em; text-transform:uppercase;
  color:var(--rose); font-weight:400; margin-bottom:14px;
}
.section-title {
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(32px,3.6vw,50px);
  font-weight:400; line-height:1.1; color:var(--text);
}
.section-title em { font-style:italic; color:var(--text-mid); font-weight:300; }

/* ─── CATALOG ─────────────────────────────────────────────────────────────── */
.catalog {
  padding:112px 7% 120px;
  background:var(--bg);
}
.cat-head {
  display:flex; align-items:flex-end; justify-content:space-between;
  padding-bottom:36px; margin-bottom:52px;
  border-bottom:1px solid var(--line);
}
.cat-desc {
  font-size:12.5px; color:var(--text-muted); font-weight:300;
  letter-spacing:.03em; line-height:1.82; max-width:260px; text-align:right;
}

/* Filters */
.filters { display:flex; gap:8px; margin-bottom:56px; flex-wrap:wrap; }
.fpill {
  font-size:9.5px; letter-spacing:.2em; text-transform:uppercase;
  padding:9px 22px; background:transparent; cursor:pointer;
  color:var(--text-muted); border:1px solid var(--line);
  transition:all .3s; font-family:'Jost',sans-serif; font-weight:400;
}
.fpill:hover { border-color:var(--rose-dark); color:var(--text); }
.fpill.on { background:var(--rose-deep); color:#fff; border-color:var(--rose-deep); }

/* Grid */
.pgrid { display:grid; grid-template-columns:repeat(3,1fr); gap:48px 32px; }

/* Card */
.pcard { position:relative; }

.pcard-img {
  position:relative; aspect-ratio:3/4; overflow:hidden;
  background:var(--bg2); margin-bottom:20px;
  border:1px solid var(--line);
  transition:border-color .35s;
}
.pcard:not(.out):hover .pcard-img { border-color:var(--rose); }

.pcard-visual {
  width:100%; height:100%;
  display:flex; align-items:center; justify-content:center;
  transition:transform .75s var(--ease);
}
.pcard:not(.out):hover .pcard-visual { transform:scale(1.03); }

/* Sold-out */
.sold-ov {
  position:absolute; inset:0;
  background:rgba(243,239,233,.78);
  display:flex; align-items:center; justify-content:center;
  pointer-events:none;
}
.sold-badge {
  font-size:8px; letter-spacing:.28em; text-transform:uppercase;
  color:var(--text-muted); border:1px solid var(--text-muted);
  padding:6px 16px; background:var(--white);
}

/* Slide-up action */
.pcard-action {
  position:absolute; bottom:0; left:0; right:0;
  padding:20px;
  background:linear-gradient(to top, rgba(101,60,43,.85), transparent);
  transform:translateY(101%);
  transition:transform .5s var(--ease);
  display:flex; justify-content:center;
}
.pcard:not(.out):hover .pcard-action { transform:translateY(0); }
.slide-btn {
  font-size:9px; letter-spacing:.22em; text-transform:uppercase;
  color:#fff; background:transparent;
  border:1px solid rgba(255,255,255,.45);
  padding:9px 22px; cursor:pointer;
  transition:background .3s, border-color .3s;
  font-family:'Jost',sans-serif; display:inline-block;
}
.slide-btn:hover { background:var(--rose-dark); border-color:var(--rose-dark); }

/* New badge */
.new-b {
  position:absolute; top:14px; left:14px;
  font-size:7.5px; letter-spacing:.24em; text-transform:uppercase;
  background:var(--rose-deep); color:#fff; padding:5px 11px;
}
.promo-b {
  position:absolute; top:14px; right:14px;
  font-size:11px; font-weight:700; letter-spacing:.04em;
  font-family:'Jost',sans-serif;
  background:#B5544A; color:#fff; padding:5px 10px; border-radius:3px;
}

/* Info */
.pname {
  font-family:'Cormorant Garamond',serif;
  font-size:20px; font-weight:400; color:var(--text); margin-bottom:5px;
  transition:color .3s;
}
.pcard:not(.out):hover .pname { color:var(--rose-deep); }
.pmeta { display:flex; align-items:center; justify-content:space-between; margin-bottom:14px; }
.pcat {
  font-size:9px; letter-spacing:.18em; text-transform:uppercase; color:var(--text-muted);
}
.pprice {
  font-family:'Cormorant Garamond',serif;
  font-size:18px; color:var(--rose-dark); font-weight:400;
}
.out .pname  { color:var(--text-muted); }
.out .pprice { color:var(--text-muted); }

/* WhatsApp button — PRIMARY */
.pwa {
  display:flex; align-items:center; justify-content:center; gap:9px;
  font-size:9.5px; letter-spacing:.2em; text-transform:uppercase;
  background:var(--rose-dark); color:#fff; border:1px solid var(--rose-dark);
  padding:13px 16px; cursor:pointer; font-family:'Jost',sans-serif;
  font-weight:400; transition:background .3s, border-color .3s;
}
.pwa:hover { background:var(--rose-deep); border-color:var(--rose-deep); }
.pwa svg { flex-shrink:0; }

/* ─── STATS STRIP ─────────────────────────────────────────────────────────── */
.stats {
  background: var(--bg2);
  padding: 56px 6%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  overflow-x: hidden;
}
.stat {
  text-align: center;
  padding: 16px 0;
  border-right: none;
  width: 100%;
}
.stat:last-child {
  border-right: none;
}
.stat-n {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(14px, 4.6vw, 32px);
  font-weight: 300;
  font-style: italic;
  color: var(--rose-dark);
  line-height: 1.6;
  margin-bottom: 0;
  white-space: nowrap;
  max-width: 100%;
}

/* ─── ABOUT ───────────────────────────────────────────────────────────────── */
.about {
  padding:112px 7%;
  display:grid; grid-template-columns:1fr 1fr; gap:96px; align-items:center;
  background:var(--white);
}
.about-visual {
  position:relative; height:520px;
  background:var(--bg); border:1px solid var(--line);
  display:flex; align-items:center; justify-content:center;
  overflow:hidden;
}
/* Offset decorative border */
.about-visual::before {
  content:''; position:absolute;
  top:20px; left:20px; right:-20px; bottom:-20px;
  border:1px solid var(--line); pointer-events:none;
}
.about-logo-big { width:200px; height:200px; opacity:.75; }
.about-deco-line {
  position:absolute; bottom:28px; left:28px; right:28px;
  height:1px; background:var(--line);
}
.about-deco-line::after {
  content:''; position:absolute; left:0; top:0;
  width:40%; height:1px; background:var(--rose);
}

.about-eyebrow { font-size:9px; letter-spacing:.42em; text-transform:uppercase; color:var(--rose); margin-bottom:16px; }
.about-title {
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(34px,3.4vw,48px); font-weight:400;
  color:var(--text); line-height:1.14; margin-bottom:24px;
}
.about-title em { font-style:italic; color:var(--text-mid); font-weight:300; }
.about-body {
  font-size:13px; color:var(--text-body); line-height:1.9;
  font-weight:300; margin-bottom:40px;
  border-left:2px solid var(--rose); padding-left:20px;
}
.about-cta {
  display:inline-flex; align-items:center; gap:14px;
  font-size:10px; letter-spacing:.22em; text-transform:uppercase;
  color:var(--rose-dark); font-weight:500;
  transition:gap .4s, color .3s;
}
.about-cta:hover { gap:22px; color:var(--rose-deep); }
.about-cta-arr { font-size:18px; line-height:1; }

/* ─── INSTAGRAM ───────────────────────────────────────────────────────────── */
.insta {
  padding:112px 7%; background:var(--bg);
  text-align:center;
}
.insta-head { margin-bottom:56px; }
.insta-grid {
  display:grid; grid-template-columns:repeat(5,1fr);
  gap:3px; margin-bottom:48px;
}
.ithumb {
  aspect-ratio:1; background:var(--bg2); overflow:hidden;
  position:relative; cursor:pointer;
  border:1px solid var(--line);
}
.ithumb::after {
  content:''; position:absolute; inset:0;
  background:rgba(101,60,43,0); transition:background .4s;
}
.ithumb:hover::after { background:rgba(101,60,43,.32); }
.ithumb-ico {
  position:absolute; inset:0;
  display:flex; align-items:center; justify-content:center; opacity:.22;
}
.insta-link {
  display:inline-flex; align-items:center; gap:11px;
  font-size:10px; letter-spacing:.22em; text-transform:uppercase;
  color:var(--text); border-bottom:1px solid var(--line); padding-bottom:4px;
  transition:color .3s, border-color .3s, gap .4s;
}
.insta-link:hover { color:var(--rose-dark); border-color:var(--rose-dark); gap:18px; }

/* ─── FOOTER ──────────────────────────────────────────────────────────────── */
footer {
  background:var(--rose-deep); padding:72px 7% 40px;
  border-top:1px solid rgba(255,255,255,.08);
}
.foot-top {
  display:grid; grid-template-columns:2fr 1fr 1fr;
  gap:64px; padding-bottom:60px;
  border-bottom:1px solid rgba(255,255,255,.08);
  margin-bottom:32px;
}
.foot-logo-row { display:flex; align-items:center; gap:14px; margin-bottom:20px; }
.foot-logo-svg { width:48px; height:48px; }
.foot-brand { font-family:'Cormorant Garamond',serif; font-size:18px; font-weight:400; letter-spacing:.14em; color:#fff; }
.foot-brand-sub { font-size:8px; letter-spacing:.3em; text-transform:uppercase; color:rgba(255,255,255,.45); }
.foot-body { font-size:12px; color:rgba(255,255,255,.38); line-height:1.85; font-weight:300; }
.foot-col-h { font-size:8px; letter-spacing:.3em; text-transform:uppercase; color:var(--rose); margin-bottom:18px; }
.foot-links { list-style:none; }
.foot-links li { margin-bottom:10px; }
.foot-links a { font-size:12px; color:rgba(255,255,255,.42); transition:color .3s; letter-spacing:.03em; }
.foot-links a:hover { color:rgba(255,255,255,.85); }
.foot-bot { display:flex; align-items:center; justify-content:space-between; }
.foot-copy { font-size:9px; color:rgba(255,255,255,.22); letter-spacing:.1em; }
.foot-rule { width:32px; height:1px; background:var(--rose); opacity:.4; }

/* ─── WA FLOAT ────────────────────────────────────────────────────────────── */
.wa-float {
  position:fixed; bottom:32px; right:32px; z-index:300;
  width:54px; height:54px; background:#8B4A3C; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 0 14px 3px rgba(37,211,102,.3), 0 4px 16px rgba(139,74,60,.28);
  animation:waf 3.2s ease-in-out infinite;
  transition:transform .3s var(--ease), box-shadow .3s;
}
.wa-float:hover { animation:none; transform:scale(1.1); box-shadow:0 0 14px 3px rgba(37,211,102,.3), 0 8px 24px rgba(139,74,60,.45); }
@keyframes waf { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }
.wa-tip {
  position:absolute; right:62px; top:50%; transform:translateY(-50%);
  background:var(--rose-deep); color:#fff;
  font-size:9px; letter-spacing:.14em; text-transform:uppercase;
  padding:7px 14px; white-space:nowrap;
  opacity:0; pointer-events:none; transition:opacity .3s;
}
.wa-float:hover .wa-tip { opacity:1; }

/* ─── ADMIN ───────────────────────────────────────────────────────────────── */
.admin-trig {
  font-size:8px; letter-spacing:.22em; text-transform:uppercase;
  color:var(--rose-deep); cursor:pointer; background:none; border:none;
  font-family:'Jost',sans-serif; transition:color .3s;
}
.admin-trig:hover { color:rgba(255,255,255,.35); }

.admin-ov {
  display:none; position:fixed; inset:0; z-index:1000;
  background:rgba(42,22,12,.92);
  align-items:center; justify-content:center;
  opacity:0; transition:opacity .35s ease;
}
.admin-ov.open { display:flex; }
.admin-ov.visible { opacity:1; }
.admin-panel {
  background:var(--bg); width:900px;
  max-width:96vw; height:82vh; max-height:760px;
  display:flex; flex-direction:column;
  overflow:hidden;
  transform:translateY(18px) scale(.97);
  transition:transform .35s cubic-bezier(.22,.68,0,1.2), opacity .35s ease;
  opacity:0;
}
.admin-ov.visible .admin-panel { transform:translateY(0) scale(1); opacity:1; }
.admin-hd {
  background:var(--rose-deep); padding:26px 38px;
  display:flex; align-items:center; justify-content:space-between;
  flex-shrink:0;
}
.admin-hd-t {
  font-family:'Cormorant Garamond',serif;
  font-size:22px; font-weight:400; color:#fff; letter-spacing:.12em;
}
.admin-x {
  background:none; border:none; color:rgba(255,255,255,.6);
  font-size:20px; cursor:pointer; transition:color .3s;
}
.admin-x:hover { color:#fff; }
.admin-bd {
  padding:28px 38px 40px; overflow-y:auto; flex:1;
  scrollbar-width:thin; scrollbar-color:var(--rose-dark) transparent;
}
.admin-bd::-webkit-scrollbar { width:6px; }
.admin-bd::-webkit-scrollbar-track { background:transparent; }
.admin-bd::-webkit-scrollbar-thumb { background:var(--rose-dark); border-radius:10px; }
.admin-bd::-webkit-scrollbar-thumb:hover { background:var(--rose-deep); }

.admin-tabs {
  display:flex; border-bottom:1px solid var(--line);
  background:var(--bg); overflow-x:auto; flex-shrink:0;
  -ms-overflow-style:none; scrollbar-width:none;
}
.admin-tabs::-webkit-scrollbar { display:none; }
.atab {
  flex:1; text-align:center;
  font-size:9px; letter-spacing:.2em; text-transform:uppercase;
  padding:12px 16px; background:none; border:none;
  color:var(--text-muted); cursor:pointer; font-family:'Jost',sans-serif;
  border-bottom:2px solid transparent; margin-bottom:-1px; transition:all .3s;
  white-space:nowrap;
}
.atab.on { color:var(--text); border-bottom-color:var(--rose-dark); }

.apane { display:none; }
#favBanner img { transition: opacity 0.5s ease; }
.fav-slide-fade { animation: favFade 0.5s ease; }
@keyframes favFade { from{opacity:0;transform:translateX(18px)} to{opacity:1;transform:translateX(0)} }
.apane.on { display:block; }

.frow { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px; }
.fg { display:flex; flex-direction:column; gap:6px; }
.fg.full { grid-column:1/-1; }
.flabel { font-size:8px; letter-spacing:.25em; text-transform:uppercase; color:var(--text-muted); }
.fi {
  font-family:'Jost',sans-serif; font-size:13px; padding:12px 14px;
  border:1px solid var(--line); background:var(--white);
  color:var(--text); outline:none; transition:border-color .3s; width:100%;
}
.fi:focus { border-color:var(--rose-dark); }
.fb {
  font-family:'Jost',sans-serif; font-size:9px; letter-spacing:.22em; text-transform:uppercase;
  padding:13px 28px; background:var(--rose-dark); color:#fff;
  border:1px solid var(--rose-dark); cursor:pointer; transition:background .3s, border-color .3s;
  margin-top:8px;
}
.fb:hover { background:var(--rose-deep); border-color:var(--rose-deep); }

.alist { margin-top:24px; }
.arow {
  display:flex; align-items:center;
  padding:14px 10px; border-bottom:1px solid var(--line);
}
.arow:nth-child(even) { background:rgba(182,139,115,.06); }
.arow:nth-child(odd)  { background:rgba(243,239,233,.55); }
.arow-btns { overflow-x:auto; display:flex; align-items:center; gap:6px; flex:1; min-width:0; padding-left:6px; }
/* esconder scrollbar mas manter funcionalidade */
.arow-btns::-webkit-scrollbar { display:none; }
.arow-btns { -ms-overflow-style:none; scrollbar-width:none; }
#alist-btns-wrap::-webkit-scrollbar { display:none; }
.alist-btns::-webkit-scrollbar { display:none; }
.alist-name { transition: width .4s ease-in-out, min-width .4s ease-in-out; }

/* Checkbox customizado do cabeçalho da lista */
#alist input[type=checkbox] {
  appearance:none; -webkit-appearance:none;
  width:16px; height:16px; flex-shrink:0;
  border:1.5px solid #653C2B; border-radius:3px;
  background:#F3EFE9; cursor:pointer;
  transition: background .2s, border-color .2s;
}
#alist input[type=checkbox]:checked { background:#8B4A3C; border-color:#8B4A3C; }
.athumb {
  width:44px; height:44px; background:var(--bg2); flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
  border:1px solid var(--line);
}
.aname { font-family:'Cormorant Garamond',serif; font-size:17px; color:var(--text); flex:1; }
.astatus { font-size:8px; letter-spacing:.2em; text-transform:uppercase; padding:4px 12px; }
.sa { background:rgba(37,211,102,.1); color:#1a7a3e; }
.ss { background:rgba(182,139,115,.12); color:var(--text-muted); }
.aacts { display:flex; gap:7px; }
.aabtn {
  font-size:8px; letter-spacing:.14em; text-transform:uppercase;
  padding:7px 14px; border:1px solid var(--line);
  background:transparent; color:var(--text-muted); cursor:pointer;
  font-family:'Jost',sans-serif; transition:all .3s;
}
.aabtn:hover { background:var(--rose-dark); color:#fff; border-color:var(--rose-dark); }
.aabtn.del { border-color:#b83232 !important; color:#b83232 !important; }
.aabtn.del:hover { background:#b83232 !important; color:#fff !important; border-color:#b83232 !important; }

.login-wrap {
  display:flex; flex-direction:column; gap:14px;
  max-width:340px; margin:0 auto; padding:60px 0; text-align:center;
}
.login-t {
  font-family:'Cormorant Garamond',serif; font-size:28px; font-weight:400;
  color:var(--text); letter-spacing:.1em; margin-bottom:6px;
}
.login-s { font-size:10px; color:var(--text-muted); letter-spacing:.1em; margin-bottom:24px; }
.lerr { font-size:10px; color:#7A1E1E; margin-top:8px; }

/* ─── ANIMATIONS ──────────────────────────────────────────────────────────── */
@keyframes fadeUp  { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
@keyframes fadeIn  { from{opacity:0} to{opacity:1} }
.reveal {
  opacity:0; transform:translateY(20px);
  transition:opacity .9s var(--ease), transform .9s var(--ease);
}
.reveal.vis { opacity:1; transform:translateY(0); }
.reveal-d2 { transition-delay:.12s; }
.reveal-d3 { transition-delay:.24s; }

/* ─── RESPONSIVE ──────────────────────────────────────────────────────────── */
@media(max-width:1100px) {
  .pgrid { grid-template-columns:repeat(2,1fr); }
  .insta-grid { grid-template-columns:repeat(4,1fr); }
  .insta-grid .ithumb:last-child { display:none; }
  .about { grid-template-columns:1fr; gap:56px; }
  .about-visual { height:280px; }
  .foot-top { grid-template-columns:1fr 1fr; gap:40px; }
}
@media(max-width:768px) {
  nav { padding:18px 24px; }
  nav.s { padding:13px 24px; }
  .nav-links { display:none; }
  .hero-logo { width:64px; height:64px; }
  .catalog { padding:72px 5% 80px; }
  .cat-head { flex-direction:column; align-items:flex-start; gap:14px; }
  .cat-desc { text-align:left; }
  .about { padding:72px 5%; }
  .insta { padding:72px 5%; }
  .insta-grid { grid-template-columns:repeat(3,1fr); }
  .foot-top { grid-template-columns:1fr; }
  .pgrid { gap:28px 16px; }
  body { cursor:auto; }
  .cursor,.cursor-ring { display:none; }
  .h-scroll { display:none; }
  .frow { grid-template-columns:1fr; }
  .admin-bd { padding:24px 20px; }
}

/* ── RESPONSIVE COMPLETE ─────────────────────────────────────── */

/* Large desktop */
@media(min-width:1400px){
  nav { padding:28px 80px; }
  nav.s { padding:16px 80px; }
  .catalog { padding:112px 8% 120px; }
  .about { padding:112px 8%; }
  .insta { padding:112px 8%; }
  .foot-top { padding-bottom:60px; }
  footer { padding:72px 8% 40px; }
}

/* Tablet landscape */
@media(max-width:1100px){
  .pgrid { grid-template-columns:repeat(2,1fr); gap:32px 24px; }
  .about { grid-template-columns:1fr; gap:48px; }
  .about-visual { height:260px; }
  .foot-top { grid-template-columns:1fr 1fr; gap:40px; }
  nav { padding:20px 36px; }
  nav.s { padding:13px 36px; }
}

/* Tablet portrait */
@media(max-width:820px){
  .pgrid { grid-template-columns:repeat(2,1fr); gap:24px 16px; }
  .hero-title { font-size: clamp(42px,10vw,68px); }
  .hero-sub { font-size:12px; max-width:90%; }
  .catalog { padding:64px 5% 72px; }
  .cat-head { flex-direction:column; align-items:flex-start; gap:12px; }
  .cat-desc { text-align:left; max-width:100%; }
  .about { padding:72px 5%; }
  .insta { padding:72px 5%; }
  .insta-grid { grid-template-columns:repeat(3,1fr); }
  .insta-grid .ithumb:nth-child(4),
  .insta-grid .ithumb:nth-child(5) { display:none; }
  .foot-top { grid-template-columns:1fr; gap:32px; }
  footer { padding:56px 5% 32px; }
  .marquee-strip { padding:11px 0; }
}

/* Mobile large */
@media(max-width:600px){
  nav { padding:16px 20px; }
  nav.s { padding:12px 20px; }
  .nav-links { display:none; }
  .nav-cta { font-size:9px; padding:8px 16px; }
  .nav-words-main { font-size:13px; letter-spacing:.14em; }
  
  .hero-content { left:5%; max-width:95%; }
  .hero-title { font-size:clamp(38px,11vw,60px); }
  .hero-sub { display:none; }
  .hero-btn { margin-top:8px; }

  .pgrid { grid-template-columns:1fr 1fr; gap:16px 10px; }
  .pname { font-size:16px; }
  .pprice { font-size:15px; }
  .pcat { font-size:8px; }
  .pwa { font-size:8.5px; letter-spacing:.12em; padding:10px 8px; }
  .pwa svg { display:none; }
  
  .filters { gap:6px; }
  .fpill { font-size:8.5px; padding:7px 14px; }
  
  .section-title { font-size:clamp(28px,8vw,40px); }
  .about-title { font-size:clamp(28px,8vw,40px); }
  
  .insta-grid { grid-template-columns:repeat(2,1fr); }
  .insta-grid .ithumb:nth-child(3),
  .insta-grid .ithumb:nth-child(4),
  .insta-grid .ithumb:nth-child(5) { display:none; }
  
  .wa-float { width:48px; height:48px; bottom:20px; right:20px; }
  .admin-trig { bottom:20px; left:20px; }
  
  body { cursor:auto; }
  .cursor,.cursor-ring { display:none; }
  .h-scroll { display:none; }
  
  .frow { grid-template-columns:1fr; }
  .admin-bd { padding:20px 16px; }
  .admin-panel { height:92vh; max-height:92vh; }
}

/* Mobile small */
@media(max-width:380px){
  .pgrid { grid-template-columns:1fr; }
  .hero-title { font-size:38px; }
  .nav-words-main { font-size:12px; }
  .nav-cta { display:none; }
}

/* My Favorite Looks link: header pill on desktop, hero pill on mobile */
@media(min-width:769px){
  #bijusHeroBtn { display:none !important; }
}
@media(max-width:768px){
  #navLooksBtn { display:none !important; }
  #bijusHeroBtn {
    right:auto !important; left:50% !important; top:auto !important; bottom:36px !important;
    transform:translateX(-50%) !important; padding:12px 22px !important; font-size:12px !important;
    white-space:nowrap;
  }
}

/* Touch devices: disable hover effects that need mouse */
@media(hover:none){
  .pcard-action { display:none; }
  .cursor, .cursor-ring { display:none; }
  body { cursor:auto; }
}


/* ── LOGO PNG transparente ───────────────────────────── */
.nav-logo-img { display:block; width:44px; height:44px; object-fit:contain; filter: brightness(0) invert(1); transition: filter .4s; }
nav.s .nav-logo-img { filter: none; }
.hero-logo-img { display:block; width:116px; height:auto; max-height:116px; object-fit:contain; opacity:0; animation:fadeUp 1s .35s var(--ease) forwards; }
.about-logo-img { display:block; width:min(320px,72vw); height:auto; object-fit:contain; }
.foot-logo-img  { display:block; width:170px; height:auto; object-fit:contain; filter: brightness(0) invert(1) opacity(.85); }
@media(max-width:600px){
  .nav-logo-img { width:38px; height:38px; }
  .hero-logo-img { width:88px; max-height:88px; }
  .foot-logo-img { width:150px; }
}


.pcard:not(.out):hover .bag-photo { transform: scale(1.04); }
.pcard-visual { overflow:hidden; }

/* Responsive hardening */
:root {
  --page-gutter: clamp(1rem, 4vw, 7rem);
  --section-y: clamp(4rem, 8vw, 7rem);
  --section-y-sm: clamp(3rem, 7vw, 4.5rem);
  --card-gap: clamp(1rem, 2.2vw, 2rem);
}

html, body { width:100%; max-width:100%; }
body { overflow-x:clip; }
img, svg, video, canvas { max-width:100%; height:auto; }
main, section, footer, nav, .hero, .catalog, .about, .insta, .stats { max-width:100%; }
a, button, input, select, textarea, [onclick] { touch-action:manipulation; }
a:focus-visible,
button:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible {
  outline:2px solid var(--rose);
  outline-offset:3px;
}

nav {
  gap:clamp(.75rem, 2vw, 2rem);
  padding:clamp(1rem, 2.5vw, 1.75rem) var(--page-gutter);
}
nav.s { padding:clamp(.75rem, 1.8vw, 1rem) var(--page-gutter); }
.nav-logo {
  min-width:0;
  min-height:44px;
}
.nav-words { min-width:0; }
.nav-words-main {
  font-size:clamp(.78rem, .72rem + .25vw, .94rem);
  letter-spacing:clamp(.11em, .7vw, .2em);
}
.nav-words-sub { letter-spacing:clamp(.24em, 1vw, .38em); }
.nav-links { gap:clamp(1.2rem, 3vw, 2.5rem); }
.nav-links a,
.nav-cta,
#navLooksBtn {
  min-height:44px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
}
.nav-cta {
  padding:clamp(.62rem, 1.2vw, .75rem) clamp(.9rem, 2vw, 1.5rem);
  font-size:clamp(.56rem, .5rem + .18vw, .63rem);
}
#navLooksBtn {
  max-width:min(42vw, 14rem);
  margin-right:clamp(.4rem, 1.4vw, 1.1rem) !important;
  padding:clamp(.55rem, 1vw, .7rem) clamp(.75rem, 1.6vw, 1.1rem) !important;
  font-size:clamp(.68rem, .62rem + .2vw, .78rem) !important;
  line-height:1.15;
  white-space:normal;
  text-align:center;
}
#navLooksBtn svg { flex:0 0 auto; }

.hero {
  height:100svh;
  min-height:min(42rem, 100svh);
}
.hero-content {
  left:var(--page-gutter);
  width:min(100% - (var(--page-gutter) * 2), 35rem);
}
.hero-deco {
  width:clamp(11rem, 22vw, 17.5rem);
  height:auto;
  aspect-ratio:7/8;
}
.hero-eyebrow {
  font-size:clamp(.5rem, .45rem + .18vw, .58rem);
  letter-spacing:clamp(.24em, 1.2vw, .44em);
  line-height:1.5;
  flex-wrap:wrap;
}
.hero-title {
  font-size:clamp(2.7rem, 1.7rem + 4.7vw, 5.35rem);
  line-height:1;
  text-wrap:balance;
}
.hero-title em { padding:clamp(.45rem, 1.5vw, 1rem) 0; }
.hero-sub {
  font-size:clamp(.82rem, .76rem + .2vw, .92rem);
  max-width:min(38ch, 100%);
}
.hero-btn {
  min-height:44px;
  font-size:clamp(.56rem, .5rem + .18vw, .66rem);
  letter-spacing:clamp(.14em, .8vw, .26em);
}
.h-dot {
  min-width:44px;
  min-height:44px;
  display:flex;
  align-items:center;
}
.h-dot::before {
  content:'';
  display:block;
  width:20px;
  height:1.5px;
  background:currentColor;
  opacity:0;
}
.h-dot.on { min-width:52px; }

.catalog, .insta { padding:var(--section-y) var(--page-gutter); }
.about { padding:var(--section-y) var(--page-gutter); gap:clamp(3rem, 6vw, 6rem); }
.cat-head {
  gap:clamp(1rem, 3vw, 2rem);
  padding-bottom:clamp(1.5rem, 3vw, 2.25rem);
  margin-bottom:clamp(2rem, 4vw, 3.25rem);
}
.section-title,
.about-title {
  font-size:clamp(2rem, 1.45rem + 2.6vw, 3.15rem);
  text-wrap:balance;
}
.cat-desc,
.about-body,
.foot-body {
  font-size:clamp(.82rem, .78rem + .18vw, .95rem);
}
.filters {
  gap:clamp(.45rem, 1.2vw, .75rem);
  margin-bottom:clamp(2rem, 4vw, 3.5rem);
}
.fpill {
  min-height:44px;
  padding:clamp(.55rem, 1.4vw, .72rem) clamp(.9rem, 2.4vw, 1.4rem);
  font-size:clamp(.54rem, .5rem + .16vw, .62rem);
  letter-spacing:clamp(.12em, .65vw, .2em);
}

.pgrid {
  container-type:inline-size;
  grid-template-columns:repeat(auto-fit, minmax(min(18rem, 100%), 1fr));
  gap:clamp(1.4rem, 3vw, 3rem) var(--card-gap);
}
.pcard { min-width:0; container-type:inline-size; }
.pname {
  font-size:clamp(1.05rem, .96rem + .5cqi, 1.28rem);
  line-height:1.2;
  overflow-wrap:break-word;
}
.pmeta {
  gap:.65rem;
  align-items:flex-start;
}
.pcat {
  min-width:0;
  line-height:1.35;
  overflow-wrap:anywhere;
}
.pprice {
  flex:0 0 auto;
  font-size:clamp(1rem, .94rem + .45cqi, 1.18rem);
  text-align:right;
}
.pwa,
.slide-btn,
.about-cta,
.insta-link,
.fb,
.aabtn,
.admin-trig {
  min-width:44px;
  min-height:44px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  line-height:1.25;
}
.pwa {
  width:100%;
  padding:clamp(.72rem, 2vw, .9rem) clamp(.7rem, 2vw, 1rem);
  font-size:clamp(.54rem, .5rem + .16vw, .62rem);
  letter-spacing:clamp(.1em, .65vw, .2em);
  text-align:center;
}
.stats {
  padding:clamp(2.5rem, 6vw, 3.5rem) var(--page-gutter);
}
.stat-n {
  font-size:clamp(1.1rem, .85rem + 3.4vw, 2rem);
  white-space:normal;
  text-wrap:balance;
}
.about-visual {
  min-height:clamp(15rem, 35vw, 32.5rem);
  height:auto;
  aspect-ratio:1.15/1;
}
.about-body {
  max-width:62ch;
  padding-left:clamp(.9rem, 2vw, 1.25rem);
}
.insta-link {
  max-width:100%;
  text-align:center;
  flex-wrap:wrap;
}
footer { padding:clamp(3.5rem, 6vw, 4.5rem) var(--page-gutter) clamp(2rem, 4vw, 2.5rem); }
.foot-top {
  gap:clamp(2rem, 5vw, 4rem);
  padding-bottom:clamp(2rem, 5vw, 3.75rem);
}
.foot-copy { line-height:1.7; overflow-wrap:anywhere; }
.foot-links a {
  min-height:44px;
  display:inline-flex;
  align-items:center;
}
.wa-float {
  width:clamp(3rem, 8vw, 3.4rem);
  height:clamp(3rem, 8vw, 3.4rem);
}

.admin-panel {
  width:min(56.25rem, calc(100vw - 1rem));
  max-width:calc(100vw - 1rem);
  height:min(82vh, 47.5rem);
}
.admin-hd { padding:clamp(1rem, 3vw, 1.6rem) clamp(1rem, 4vw, 2.4rem); gap:1rem; }
.admin-hd-t {
  min-width:0;
  font-size:clamp(1.15rem, .95rem + 1vw, 1.38rem);
  line-height:1.2;
  overflow-wrap:anywhere;
}
.admin-x {
  min-width:44px;
  min-height:44px;
}
.admin-bd { padding:clamp(1rem, 3vw, 1.75rem) clamp(1rem, 4vw, 2.4rem) clamp(1.5rem, 4vw, 2.5rem); }
.admin-tabs { gap:0; }
.atab {
  flex:0 0 auto;
  min-height:44px;
  padding:.75rem 1rem;
}
.fi { min-height:44px; font-size:1rem; }
#alist input[type=checkbox] {
  width:1.5rem;
  height:1.5rem;
  min-width:1.5rem;
}

/* Eyebrows / small caps labels: fluid letter-spacing so mobile stays legible */
.eyebrow,
.about-eyebrow {
  font-size:clamp(.5rem, .46rem + .15vw, .56rem);
  letter-spacing:clamp(.2em, 1vw, .42em);
}
.m-item {
  font-size:clamp(.5rem, .46rem + .15vw, .56rem);
  letter-spacing:clamp(.18em, 1vw, .36em);
}
.h-scroll-txt {
  letter-spacing:clamp(.18em, 1vw, .34em);
}
.new-b {
  font-size:clamp(.42rem, .38rem + .15vw, .47rem);
  letter-spacing:clamp(.12em, .8vw, .24em);
}
.sold-badge {
  font-size:clamp(.44rem, .4rem + .15vw, .5rem);
  letter-spacing:clamp(.14em, .8vw, .28em);
}
.astatus {
  font-size:clamp(.44rem, .4rem + .15vw, .5rem);
  letter-spacing:clamp(.1em, .6vw, .2em);
}
.aabtn {
  font-size:clamp(.44rem, .4rem + .15vw, .5rem);
  letter-spacing:clamp(.08em, .5vw, .14em);
}

@container (max-width: 23rem) {
  .pmeta {
    flex-direction:column;
    gap:.35rem;
  }
  .pprice { text-align:left; }
}

@media(max-width:820px){
  .hero-content { width:min(90vw, 34rem); }
  .hero-title { font-size:clamp(2.45rem, 10vw, 4.25rem); }
  .hero-sub { max-width:38ch; }
  .cat-head { align-items:flex-start; }
  .cat-desc { text-align:left; max-width:42rem; }
}

@media(max-width:600px){
  :root { --page-gutter: clamp(1rem, 5vw, 1.35rem); }
  nav { align-items:center; }
  .hero-content { top:48%; max-width:none; }
  .hero-title { font-size:clamp(2.35rem, 11vw, 3.75rem); margin-bottom:1rem; }
  .hero-sub { display:block; font-size:.8rem; line-height:1.7; margin-bottom:1.35rem; max-width:31ch; }
  .hero-logo-img { width:clamp(4.8rem, 24vw, 5.5rem); }
  .catalog, .about, .insta { padding-block:var(--section-y-sm); }
  .pgrid { grid-template-columns:repeat(2, minmax(0, 1fr)); gap:1.2rem .75rem; }
  .pcard-img { margin-bottom:.8rem; }
  .pname { font-size:clamp(1rem, 4.5vw, 1.12rem); }
  .pmeta { flex-direction:column; gap:.25rem; margin-bottom:.75rem; }
  .pprice { text-align:left; }
  .pwa { min-height:44px; }
  .filters { align-items:stretch; }
  .fpill { flex:1 1 calc(50% - .5rem); }
  .about-visual::before { inset:.9rem -.9rem -.9rem .9rem; }
  .foot-bot { align-items:flex-start; gap:1rem; flex-direction:column; }
  .wa-tip { display:none; }
  .admin-panel { height:calc(100svh - 1rem); max-height:calc(100svh - 1rem); }
}

@media(max-width:430px){
  .nav-logo { gap:.65rem; }
  .nav-logo-img { width:2.25rem; height:2.25rem; }
  .nav-words-main { font-size:.76rem; max-width:9rem; }
  .nav-words-sub { font-size:.46rem; }
  .nav-cta { padding-inline:.75rem; letter-spacing:.12em; }
  .hero-eyebrow::before { width:1.1rem; }
  .hero-title { font-size:clamp(2.15rem, 11vw, 3.15rem); }
  .hero-sub { max-width:28ch; }
  #bijusHeroBtn {
    max-width:calc(100vw - 2rem);
    bottom:1.1rem !important;
    min-height:44px;
    white-space:normal !important;
    text-align:center;
  }
  .section-title, .about-title { font-size:clamp(1.8rem, 8vw, 2.45rem); }
  .stats { padding-inline:1rem; }
  .stat-n { font-size:clamp(1rem, 5.2vw, 1.45rem); }
  .about-body { line-height:1.78; }
  .admin-hd { align-items:flex-start; }
}

@media(max-width:380px){
  .nav-cta { display:none; }
  .pgrid { grid-template-columns:1fr; }
  .fpill { flex-basis:100%; }
}

</style>
</head>
<body>

<!-- Cursor -->
<div class="cursor" id="cur"></div>
