<!-- ADMIN OVERLAY -->
<div class="admin-ov" id="adminOv">
  <div class="admin-panel">
    <div class="admin-hd">
      <span class="admin-hd-t">Painel Administrativo</span>
      <button class="admin-x" onclick="closeA()">✕</button>
    </div>
