<script src="data/products-bags.js"></script>
<script>
// ─── CONSTANTS ────────────────────────────────────────────────────────────────
const ROSE      = '#B68B73';
const ROSE_DARK = '#915E48';
const ROSE_DEEP = '#653C2B';
const BG        = '#F3EFE9';
const BG2       = '#E7E2D9';
const LINE      = 'rgba(182,139,115,.18)';
const HERO_SLIDES = ['webp/bolsa-02.webp','webp/bolsa-03.webp','webp/bolsa-04.webp','webp/bolsa-05.webp'];

// ─── PRODUCTS ────────────────────────────────────────────────────────────────
// Dados agora vêm de data/products-bags.js (window.MFB_BAGS) — fonte única
// compartilhada com match.html. Editar aqui edita apenas a cópia em memória
// desta sessão (sem persistência real em disco, como já era o caso antes).
let products = window.MFB_BAGS;

// ─── STATUS (3 estados) ───────────────────────────────────────────────────────
const STATUS_LABEL = { available:'DISPONÍVEL', sold_out:'ESGOTADO', coming_soon:'EM BREVE' };
const STATUS_BADGE = { available:'Disponível', sold_out:'Esgotado', coming_soon:'Em Breve' };
const STATUS_COLOR = {
  available:   { bg:'rgba(37,211,102,.1)',  border:'rgba(37,211,102,.4)', text:'#1a7a3e' },
  sold_out:    { bg:'rgba(184,50,50,.1)',   border:'rgba(184,50,50,.4)',  text:'#b83232' },
  coming_soon: { bg:'rgba(201,122,61,.12)', border:'rgba(201,122,61,.45)', text:'#C97A3D' },
};
function statusBtnCss(st) {
  const c = STATUS_COLOR[st] || STATUS_COLOR.available;
  return `background:${c.bg};border:1px solid ${c.border};color:${c.text};`;
}
function nextStatus(st) {
  return st === 'available' ? 'sold_out' : st === 'sold_out' ? 'coming_soon' : 'available';
}

const CATS = { tote:'Tote Bag', shoulder:'Shoulder', clutch:'Clutch', mini:'Mini Bag' };

// Bag SVG illustrations — using brand palette
function bagSVG(cat, color) {
  const svgs = {
    tote: `<svg viewBox="0 0 200 220" fill="none" width="108" height="120">
      <path d="M58 84Q58 54 100 54Q142 54 142 84" stroke="${color}" stroke-width="2.2" fill="none"/>
      <rect x="28" y="84" width="144" height="112" rx="8" fill="none" stroke="${color}" stroke-width="1.8"/>
      <line x1="28" y1="114" x2="172" y2="114" stroke="${color}" stroke-width="1" opacity=".4"/>
      <circle cx="100" cy="99" r="6" stroke="${color}" stroke-width="1.8" fill="none"/>
      <line x1="100" y1="105" x2="100" y2="114" stroke="${color}" stroke-width="1.2"/>
    </svg>`,
    shoulder: `<svg viewBox="0 0 200 220" fill="none" width="108" height="120">
      <path d="M42 100L32 190Q32 198 40 198L160 198Q168 198 168 190L158 100Z" stroke="${color}" stroke-width="1.8" fill="none"/>
      <path d="M70 100Q70 66 100 66Q130 66 130 100" stroke="${color}" stroke-width="1.8" fill="none"/>
      <line x1="32" y1="150" x2="168" y2="150" stroke="${color}" stroke-width=".9" opacity=".38"/>
      <ellipse cx="100" cy="136" rx="18" ry="12" stroke="${color}" stroke-width="1.1" fill="none" opacity=".45"/>
    </svg>`,
    clutch: `<svg viewBox="0 0 200 220" fill="none" width="108" height="120">
      <rect x="22" y="78" width="156" height="92" rx="9" fill="none" stroke="${color}" stroke-width="1.8"/>
      <path d="M52 78Q52 48 100 48Q148 48 148 78" stroke="${color}" stroke-width="1.8" fill="none"/>
      <line x1="22" y1="108" x2="178" y2="108" stroke="${color}" stroke-width=".9" opacity=".4"/>
      <rect x="84" y="99" width="32" height="16" rx="4" stroke="${color}" stroke-width="1.3" fill="none"/>
    </svg>`,
    mini: `<svg viewBox="0 0 200 220" fill="none" width="108" height="120">
      <rect x="52" y="82" width="96" height="106" rx="11" fill="none" stroke="${color}" stroke-width="1.8"/>
      <path d="M72 82Q72 58 100 58Q128 58 128 82" stroke="${color}" stroke-width="1.8" fill="none"/>
      <circle cx="100" cy="138" r="11" stroke="${color}" stroke-width="1.4" fill="none"/>
      <line x1="100" y1="127" x2="100" y2="149" stroke="${color}" stroke-width="1.1"/>
      <line x1="89" y1="138" x2="111" y2="138" stroke="${color}" stroke-width="1.1"/>
    </svg>`,
  };
  return svgs[cat] || svgs.tote;
}

function waMsg(name, status) {
  status = status || 'available';
  const texts = {
    available:   `Olá! Tenho interesse na bolsa *${name}*. Pode me dar mais informações?`,
    sold_out:    `Olá! Vi a bolsa *${name}* esgotada no site. Ela está indisponível no momento? Existe previsão de chegada/reposição?`,
    coming_soon: `Olá! Vi a bolsa *${name}* como "Em Breve" no site. Existe previsão de chegada?`,
  };
  return `https://wa.me/5581995966968?text=${encodeURIComponent(texts[status] || texts.available)}`;
}

// ─── RENDER PRODUCTS ──────────────────────────────────────────────────────────
let statusFilter = 'all';
function renderProducts(filter = 'all') {
  const grid = document.getElementById('pgrid');
  let list = filter === 'all' ? products : products.filter(p => p.cat === filter);
  if (statusFilter !== 'all') list = list.filter(p => p.status === statusFilter);

  grid.innerHTML = list.map(p => {
    const isAvail = p.status === 'available';
    const ic  = isAvail ? ROSE      : '#C0B4AB';
    const bg  = isAvail ? '#FFFFFF' : BG2;
    const ovText = p.status === 'sold_out' ? 'Esgotado' : p.status === 'coming_soon' ? 'Em Breve' : '';

    return `
    <div class="pcard ${isAvail ? '' : 'out'}" data-id="${p.id}">
      <div class="pcard-img" style="background:${bg}">
        <div class="pcard-visual" style="padding:0;cursor:pointer;" onclick="openBagModal(${p.id})">${p.img ? `<img src="${p.img}" alt="${p.name}" style="width:100%;height:100%;object-fit:cover;transition:transform .75s var(--ease);" class="bag-photo">` : bagSVG(p.cat, ic)}</div>
        ${!isAvail ? `<div class="sold-ov"><div class="sold-badge">${ovText}</div></div>` : ''}
        ${p.isNew && isAvail ? `<div class="new-b">Novo</div>` : ''}
        ${isAvail && p.promo && p.promo.showPct && p.promo.pct ? `<div class="promo-b">-${p.promo.pct}%</div>` : ''}
        <div class="pcard-action">
          <button onclick="openBagModal(${p.id})" class="slide-btn" style="border:none;cursor:pointer;">Ver Detalhes</button>
        </div>
      </div>
      <div class="pname">${p.name}</div>
      <div class="pmeta">
        <span class="pcat">${CATS[p.cat]}</span>
        <span class="pprice">
          ${isAvail
            ? (p.promo
                ? `<span style="text-decoration:line-through;color:#B5544A;font-size:14px;margin-right:6px;">${p.promo.old}</span><span style="color:var(--rose-dark);">${p.promo.new}</span>`
                : p.price)
            : p.price}
        </span>
      </div>
      <a href="${waMsg(p.name, p.status)}" target="_blank" class="pwa">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        ${p.status === 'available' ? 'Comprar via WhatsApp' : p.status === 'sold_out' ? 'Perguntar Disponibilidade' : 'Perguntar Previsão'}
      </a>
    </div>`;
  }).join('');
}

let lastCatFilter = 'all';
function fp(cat, btn) {
  document.querySelectorAll('#catFilters .fpill').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  lastCatFilter = cat;
  renderProducts(cat);
}

function fpStatus(st, btn) {
  document.querySelectorAll('#statusFilters .fpill').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  statusFilter = st;
  renderProducts(lastCatFilter);
}

// ─── HERO SLIDER ──────────────────────────────────────────────────────────────
let cur = 0;
function gS(n) {
  document.querySelectorAll('.hero-slide')[cur].classList.remove('active');
  document.querySelectorAll('.h-dot')[cur].classList.remove('on');
  cur = n;
  document.querySelectorAll('.hero-slide')[cur].classList.add('active');
  document.querySelectorAll('.h-dot')[cur].classList.add('on');
}
setInterval(() => gS((cur + 1) % 4), 5000);

// ─── NAV ──────────────────────────────────────────────────────────────────────
window.addEventListener('scroll', () =>
  document.getElementById('nav').classList.toggle('s', scrollY > 60));

// ─── REVEAL ON SCROLL ─────────────────────────────────────────────────────────
const ro = new IntersectionObserver(es =>
  es.forEach(e => { if (e.isIntersecting) e.target.classList.add('vis'); }),
  { threshold: .1 }
);
document.querySelectorAll('.reveal').forEach(el => ro.observe(el));

// ─── CURSOR ───────────────────────────────────────────────────────────────────
const curEl = document.getElementById('cur');
const ringEl = document.getElementById('ring');
document.addEventListener('mousemove', e => {
  curEl.style.left = e.clientX + 'px';
  curEl.style.top  = e.clientY + 'px';
  setTimeout(() => {
    ringEl.style.left = e.clientX + 'px';
    ringEl.style.top  = e.clientY + 'px';
  }, 80);
});
document.querySelectorAll('a, button, .fpill, .pcard:not(.out), .h-dot, .ithumb').forEach(el => {
  el.addEventListener('mouseenter', () => { curEl.classList.add('h'); ringEl.classList.add('h'); });
  el.addEventListener('mouseleave', () => { curEl.classList.remove('h'); ringEl.classList.remove('h'); });
});

// ─── ADMIN ────────────────────────────────────────────────────────────────────
let loggedIn = (function(){
  const t = sessionStorage.getItem('mfb_auth_ts');
  return t && (Date.now() - parseInt(t)) < 600000;
})();
const ADMIN_PASS = 'mfb2025';

function openA() {
  const ov = document.getElementById('adminOv');
  ov.classList.add('open');
  requestAnimationFrame(() => requestAnimationFrame(() => ov.classList.add('visible')));
  if (loggedIn) {
    renderPanel();
    setTimeout(() => {
      const bd = document.getElementById('adminBd');
      if (bd) bd.scrollTop = 0;
    }, 50);
  } else {
    renderLogin();
  }
}
function closeA() {
  const ov = document.getElementById('adminOv');
  ov.classList.remove('visible');
  setTimeout(() => ov.classList.remove('open'), 350);
}

function renderLogin() {
  document.getElementById('adminTabs').style.display = 'none';
  document.getElementById('adminBd').innerHTML = `
  <div class="login-wrap">
    <div class="login-t">Acesso Restrito</div>
    <p class="login-s">Painel · My Favorite Bags</p>
    <input class="fi" type="password" id="pw" placeholder="Senha de acesso"/>
    <button class="fb" onclick="tryLogin()">Entrar</button>
    <p class="lerr" id="lerr"></p>
  </div>`;
}

function tryLogin() {
  if (document.getElementById('pw').value === ADMIN_PASS) {
    loggedIn = true; sessionStorage.setItem('mfb_auth_ts', Date.now()); renderPanel();
  } else {
    document.getElementById('lerr').textContent = 'Senha incorreta. Tente novamente.';
  }
}

function renderPanel() {
  document.getElementById('adminTabs').style.display = 'flex';
  // Garantir que a tab visual sempre começa em Visão Geral
  document.querySelectorAll('#adminTabs .atab').forEach(t => t.classList.remove('on'));
  const firstTab = document.querySelector('#adminTabs .atab');
  if (firstTab) firstTab.classList.add('on');
  document.getElementById('adminBd').innerHTML = `
  <div class="apane on" id="tab-overview">
    <div id="overviewBody"></div>
  </div>

  <div class="apane" id="tab-add">
    <div class="frow">
      <div class="fg"><label class="flabel">Nome da Bolsa</label><input class="fi" id="nn" placeholder="Ex: Tote Milano"/></div>
      <div class="fg"><label class="flabel">Preço</label><input class="fi" id="np" placeholder="R$ 299"/></div>
    </div>
    <div class="frow">
      <div class="fg"><label class="flabel">Categoria</label>
        <select class="fi" id="nc">
          <option value="tote">Tote Bag</option>
          <option value="shoulder">Shoulder</option>
          <option value="clutch">Clutch</option>
          <option value="mini">Mini Bag</option>
        </select>
      </div>
      <div class="fg"><label class="flabel">Disponibilidade</label>
        <select class="fi" id="na">
          <option value="available">Disponível</option>
          <option value="sold_out">Esgotado</option>
          <option value="coming_soon">Em Breve</option>
        </select>
      </div>
    </div>
    <div class="frow">
      <div class="fg"><label class="flabel">Badge "Novo"</label>
        <select class="fi" id="nin">
          <option value="true">Sim</option>
          <option value="false">Não</option>
        </select>
      </div>
    </div>
    <button class="fb" onclick="addProd()">+ Adicionar ao Catálogo</button>
    <p id="addMsg" style="font-size:10px;margin-top:10px;"></p>
  </div>

  <div class="apane" id="tab-manage">
    <div class="alist" id="alist"></div>
  </div>

  <div class="apane" id="tab-banner">
    <p style="font-size:12.5px;color:var(--text-body);line-height:1.75;margin-bottom:24px;">
      Imagens atualmente publicadas no carrossel do banner. No site final com backend, faça upload das fotos aqui diretamente.
    </p>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
      ${HERO_SLIDES.map((img,idx) => `
      <div style="position:relative;aspect-ratio:3/4;overflow:hidden;border-radius:6px;border:1px solid ${LINE};background:#2A1F18;">
        <img id="bannerImg-${idx}" src="${img}" alt="Slide ${idx+1}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
        <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(20,12,7,.88) 0%, rgba(20,12,7,.35) 45%, rgba(20,12,7,.15) 100%);"></div>
        <div style="position:absolute;left:0;right:0;bottom:0;padding:16px;text-align:center;">
          <p style="font-size:8px;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:4px;">Slide ${idx+1}</p>
          <p style="font-size:11px;color:rgba(255,255,255,.55);margin-bottom:10px;">Publicado no banner</p>
          <button class="fb" style="font-size:8px;padding:8px 16px;margin-top:0;" onclick="triggerBannerUpload(${idx})">Trocar Imagem</button>
          <input type="file" id="bannerFile-${idx}" accept="image/*" style="display:none;" onchange="handleBannerUpload(${idx},this)">
        </div>
      </div>`).join('')}
    </div>
  </div>

  <div style="border-top:1px solid var(--line);margin-top:28px;padding-top:20px;text-align:right;">
    <button onclick="openReview()" style="background:var(--rose-deep);color:#fff;border:none;border-radius:8px;padding:12px 24px;font-size:12px;font-weight:700;cursor:pointer;letter-spacing:.06em;">Revisar e Salvar →</button>
  </div>`;
  renderOverviewTab();
  renderAdminList();
}

let _analyticsPeriod = '30d';
let _analyticsFrom = null, _analyticsTo = null;

function setAnalyticsPeriod(k) {
  _analyticsPeriod = k;
  document.querySelectorAll('[id^="apbtn-"]').forEach(b => {
    const active = b.id === 'apbtn-' + k;
    b.style.border = active ? '1px solid #8B4A3C' : '1px solid var(--line)';
    b.style.background = active ? 'rgba(139,74,60,.1)' : 'transparent';
    b.style.color = active ? '#8B4A3C' : '#A08070';
  });
  const picker = document.getElementById('analyticsPeriodPicker');
  if (picker) picker.style.display = k === 'custom' ? 'block' : 'none';
  if (k !== 'custom') renderAnalyticsBody();
}

function applyCustomPeriod() {
  const from = document.getElementById('apFrom').value;
  const to   = document.getElementById('apTo').value;
  if (!from || !to) return;
  _analyticsFrom = new Date(from).getTime();
  _analyticsTo   = new Date(to).getTime() + 86400000 - 1;
  renderAnalyticsBody();
}

function inPeriod(ts) {
  const now = Date.now();
  if (_analyticsPeriod === 'custom') return ts >= _analyticsFrom && ts <= _analyticsTo;
  const ms = {
    '1d': 86400000, '7d': 604800000, '30d': 2592000000, '365d': 31536000000
  }[_analyticsPeriod] || Infinity;
  return ts >= now - ms;
}

function countArr(arr) {
  if (!Array.isArray(arr)) return 0;
  return arr.filter(ts => inPeriod(ts)).length;
}

function renderAnalyticsBody() {
  const body = document.getElementById('analyticsBody');
  if (!body) return;
  const ids = [...new Set([...Object.keys(analytics.views), ...Object.keys(analytics.wa)])].map(Number);
  if (!ids.length) { body.innerHTML = '<p style="font-size:12px;color:#A08070;">Nenhum clique registrado ainda.</p>'; return; }

  let grandTotal = 0;
  const rows = ids.map(id => {
    const p = products.find(x => x.id === id);
    if (!p) return '';
    const cat = countArr(analytics.views[id]?.catalog);
    const fav = countArr(analytics.views[id]?.fav);
    const wa  = countArr(analytics.wa[id]);
    const tot = cat + fav + wa;
    grandTotal += tot;
    return `<div style="padding:7px 0;border-bottom:1px solid var(--line);">
      <div style="display:flex;justify-content:space-between;align-items:baseline;">
        <div style="font-size:12px;font-weight:600;color:#653C2B;">${p.name}</div>
        <div style="font-size:11px;font-weight:700;color:#8B4A3C;">${tot} clique${tot!==1?'s':''}</div>
      </div>
      <div style="font-size:11px;color:#A08070;margin-top:2px;">
        <span style="color:#8B4A3C;">👁</span> Catálogo: <b>${cat}</b> · Favoritos: <b>${fav}</b> &nbsp;|&nbsp;
        <span style="color:#8B4A3C;">💬</span> WhatsApp: <b>${wa}</b>
      </div>
    </div>`;
  }).join('');

  body.innerHTML = rows + `
    <div style="margin-top:10px;padding-top:10px;border-top:2px solid var(--rose);display:flex;justify-content:space-between;align-items:center;">
      <span style="font-size:11px;font-weight:600;color:#A08070;letter-spacing:.1em;">TOTAL</span>
      <span style="font-size:14px;font-weight:800;color:#8B4A3C;">${grandTotal} clique${grandTotal!==1?'s':''}</span>
    </div>`;
}

function renderOverviewTab() {
  const el = document.getElementById('overviewBody');
  if (!el) return;
  const favs  = products.filter(p => p.favorite);
  const avail = products.filter(p => p.status === 'available');
  const esgot = products.filter(p => p.status === 'sold_out');
  const embreve = products.filter(p => p.status === 'coming_soon');
  const novas = products.filter(p => p.isNew);
  el.innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:18px;">
      <div style="background:#faf7f4;border-radius:10px;padding:18px;text-align:center;">
        <div style="font-size:28px;font-weight:800;color:#8B4A3C;">${products.length}</div>
        <div style="font-size:10px;letter-spacing:.12em;color:#A08070;text-transform:uppercase;margin-top:4px;">Total de Bolsas</div>
      </div>
      <div style="background:#faf7f4;border-radius:10px;padding:18px;text-align:center;">
        <div style="font-size:28px;font-weight:800;color:#1a7a3e;">${avail.length}</div>
        <div style="font-size:10px;letter-spacing:.12em;color:#A08070;text-transform:uppercase;margin-top:4px;">Disponíveis</div>
      </div>
      <div style="background:#faf7f4;border-radius:10px;padding:18px;text-align:center;">
        <div style="font-size:28px;font-weight:800;color:#7A1E1E;">${esgot.length}</div>
        <div style="font-size:10px;letter-spacing:.12em;color:#A08070;text-transform:uppercase;margin-top:4px;">Esgotadas</div>
      </div>
      <div style="background:#faf7f4;border-radius:10px;padding:18px;text-align:center;">
        <div style="font-size:28px;font-weight:800;color:#C97A3D;">${embreve.length}</div>
        <div style="font-size:10px;letter-spacing:.12em;color:#A08070;text-transform:uppercase;margin-top:4px;">Em Breve</div>
      </div>
      <div style="background:#faf7f4;border-radius:10px;padding:18px;text-align:center;">
        <div style="font-size:28px;font-weight:800;color:var(--rose-deep);">${favs.length}</div>
        <div style="font-size:10px;letter-spacing:.12em;color:#A08070;text-transform:uppercase;margin-top:4px;">Favoritas</div>
      </div>
    </div>
    <div style="background:#faf7f4;border-radius:10px;padding:16px 18px;margin-bottom:12px;">
      <p style="font-weight:700;font-size:12px;margin-bottom:10px;color:#8B4A3C;">★ Favoritas do Momento</p>
      ${favs.length
        ? favs.map(p => `<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--line);font-size:12px;"><span style="color:#653C2B;">${p.name}</span><span style="color:#8B4A3C;font-weight:600;">${p.price}</span></div>`).join('')
        : `<p style="font-size:12px;color:#A08070;">Nenhuma marcada.</p>`}
    </div>
    <div style="background:#faf7f4;border-radius:10px;padding:16px 18px;margin-top:12px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap;gap:8px;">
        <p style="font-weight:700;font-size:12px;color:#8B4A3C;margin:0;">👜 Cliques por Bolsa</p>
        <div style="display:flex;gap:4px;flex-wrap:wrap;">
          ${['1d','7d','30d','365d','custom'].map(k => `
          <button onclick="setAnalyticsPeriod('${k}')" id="apbtn-${k}"
            style="font-size:9px;padding:3px 8px;border:1px solid ${k==='30d'?'#8B4A3C':'var(--line)'};
                   background:${k==='30d'?'rgba(139,74,60,.1)':'transparent'};
                   color:${k==='30d'?'#8B4A3C':'#A08070'};cursor:pointer;border-radius:4px;
                   font-family:'Jost',sans-serif;letter-spacing:.08em;">
            ${k==='1d'?'1 dia':k==='7d'?'7 dias':k==='30d'?'30 dias':k==='365d'?'1 ano':'Período'}
          </button>`).join('')}
        </div>
      </div>
      <div id="analyticsPeriodPicker" style="display:none;margin-bottom:10px;display:none;">
        <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
          <input type="date" id="apFrom" style="font-size:11px;padding:4px 6px;border:1px solid var(--line);background:var(--bg);color:var(--text);border-radius:4px;">
          <span style="font-size:11px;color:#A08070;">até</span>
          <input type="date" id="apTo" style="font-size:11px;padding:4px 6px;border:1px solid var(--line);background:var(--bg);color:var(--text);border-radius:4px;">
          <button onclick="applyCustomPeriod()" style="font-size:10px;padding:4px 10px;border:1px solid #8B4A3C;color:#8B4A3C;background:transparent;cursor:pointer;border-radius:4px;">OK</button>
        </div>
      </div>
      <div id="analyticsBody">
        <p style="font-size:12px;color:#A08070;">Nenhum clique registrado ainda.</p>
      </div>
    </div>

    <div id="centralPanel" style="margin-top:20px;padding:18px 20px;border:1px solid var(--line);border-radius:10px;background:#faf7f4;">
      <p style="font-size:13px;font-weight:700;color:#8B4A3C;margin-bottom:4px;">🔗 Painel Central · Looks &amp; Match</p>
      <p style="font-size:11px;color:#A08070;margin-bottom:14px;">Controle o acesso às outras frentes da marca.</p>
      <div id="centralPanelRows"></div>
    </div>`;
  renderAnalyticsBody();
  renderCentralPanel();
}

// ─── PAINEL CENTRAL: BLOQUEIO / VISIBILIDADE (Looks & Match) ──────────────────
const SITE_STATE_KEY = { looks: 'mfb_looks_state', match: 'mfb_match_state' };
const SITE_LABEL      = { looks: 'My Favorite Looks', match: 'My Favorite Match' };

function getSiteState(site) {
  return localStorage.getItem(SITE_STATE_KEY[site]) || 'locked';
}
function setSiteState(site, state) {
  localStorage.setItem(SITE_STATE_KEY[site], state);
  renderCentralPanel();
  applyLooksButtonVisibility();
  applyMatchButtonVisibility();
}

const SITE_PAGE = { looks: 'looks.html', match: 'match.html' };

function renderCentralPanel() {
  const el = document.getElementById('centralPanelRows');
  if (!el) return;
  const opts = [
    { v:'locked',  l:'Bloqueado' },
    { v:'hidden',  l:'Oculto' },
    { v:'visible', l:'Visível' },
  ];
  const filterOpts = [
    { v:'all',   l:'Todos' },
    { v:'bags',  l:'Bags' },
    { v:'looks', l:'Looks' },
  ];
  const curFilter = localStorage.getItem('mfb_match_default_filter') || 'all';
  el.innerHTML = ['looks','match'].map(site => {
    const cur = getSiteState(site);
    const isMatch = site === 'match';
    return `
    <div style="padding:12px 0;border-top:1px solid var(--line);">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:8px;">
        <span style="font-size:12px;font-weight:600;color:#653C2B;padding-top:6px;">${SITE_LABEL[site]}</span>
        ${isMatch ? `
        <div style="display:flex;flex-direction:column;gap:6px;align-items:flex-start;">
          <span style="font-size:12px;font-weight:600;color:#653C2B;">Filtro de itens</span>
          <div style="display:flex;gap:4px;">
            ${filterOpts.map(o => `
            <button onclick="setMatchDefaultFilter('${o.v}')"
              style="font-size:9px;letter-spacing:.08em;padding:6px 12px;border-radius:5px;cursor:pointer;
                     font-family:'Jost',sans-serif;font-weight:600;
                     border:1px solid ${curFilter===o.v ? '#8B4A3C' : 'var(--line)'};
                     background:${curFilter===o.v ? 'rgba(139,74,60,.12)' : 'transparent'};
                     color:${curFilter===o.v ? '#8B4A3C' : '#A08070'};">${o.l}</button>`).join('')}
          </div>
        </div>` : ''}
        <a href="${SITE_PAGE[site]}?preview=1" target="_blank"
          style="font-size:8.5px;letter-spacing:.08em;padding:6px 12px;border-radius:5px;cursor:pointer;margin-top:6px;
                 font-family:'Jost',sans-serif;font-weight:600;text-decoration:none;text-transform:uppercase;
                 border:1px solid var(--line); background:var(--bg); color:#A08070;">Editar (sem publicar)</a>
      </div>
      <div style="display:flex;gap:4px;">
        ${opts.map(o => `
        <button onclick="setSiteState('${site}','${o.v}')"
          style="font-size:9px;letter-spacing:.08em;padding:6px 12px;border-radius:5px;cursor:pointer;
                 font-family:'Jost',sans-serif;font-weight:600;
                 border:1px solid ${cur===o.v ? '#8B4A3C' : 'var(--line)'};
                 background:${cur===o.v ? 'rgba(139,74,60,.12)' : 'transparent'};
                 color:${cur===o.v ? '#8B4A3C' : '#A08070'};">${o.l}</button>`).join('')}
      </div>
    </div>`;
  }).join('');
}

function setMatchDefaultFilter(v) {
  localStorage.setItem('mfb_match_default_filter', v);
  renderCentralPanel();
}

function applyLooksButtonVisibility() {
  let btn = document.getElementById('bijusHeroBtn');
  const visible = getSiteState('looks') === 'visible';
  if (visible) {
    if (!btn) {
      btn = document.createElement('a');
      btn.id = 'bijusHeroBtn';
      btn.href = 'looks.html';
      btn.style.cssText = 'position:absolute;right:7%;top:50%;transform:translateY(-50%);z-index:5;display:inline-flex;align-items:center;gap:10px;padding:16px 30px;border-radius:999px;border:1.5px solid #B8896F;color:#24343C;font-family:"Cormorant Garamond",serif;font-size:15px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;text-decoration:none;background:#F6F1EC;box-shadow:0 6px 22px rgba(36,52,60,.18);transition:box-shadow .3s, transform .3s, background .3s;';
      btn.innerHTML = 'My Favorite Looks <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#B8896F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>';
      btn.onmouseover = () => { btn.style.background = '#EADFD7'; btn.style.boxShadow = '0 8px 26px rgba(36,52,60,.26)'; btn.style.transform = 'translateY(-50%) translateY(-2px)'; };
      btn.onmouseout  = () => { btn.style.background = '#F6F1EC'; btn.style.boxShadow = '0 6px 22px rgba(36,52,60,.18)'; btn.style.transform = 'translateY(-50%)'; };
      const hero = document.getElementById('hero');
      if (hero) hero.appendChild(btn);
    }
  } else {
    if (btn) btn.remove();
  }

  const navBtn = document.getElementById('navLooksBtn');
  if (navBtn) {
    navBtn.style.display = visible ? 'inline-flex' : 'none';
    if (!navBtn._wired) {
      navBtn._wired = true;
      navBtn.onmouseover = () => { navBtn.style.background = '#EADFD7'; navBtn.style.boxShadow = '0 4px 14px rgba(36,52,60,.18)'; };
      navBtn.onmouseout  = () => { navBtn.style.background = '#F6F1EC'; navBtn.style.boxShadow = 'none'; };
    }
  }
}

const MATCH_BTN_POS_KEY = 'mfb_match_btn_pos';

function applyMatchButtonVisibility() {
  let btn = document.getElementById('matchHeroBtn');
  const visible = getSiteState('match') === 'visible';
  if (visible) {
    if (!btn) {
      btn = document.createElement('a');
      btn.id = 'matchHeroBtn';
      btn.href = 'match.html';
      btn.setAttribute('aria-label', 'Abrir My Favorite Match');
      btn.innerHTML = `<img src="webp/logo-my-favorite-match-mini.webp" alt="My Favorite Match" width="92" height="92">
        <span class="mhb-tip">My Favorite Match</span>`;
      document.body.appendChild(btn);
      placeMatchBtn(btn);
      makeMatchBtnDraggable(btn);
    }
  } else {
    if (btn) btn.remove();
  }
}

function placeMatchBtn(btn) {
  let pos = null;
  try { pos = JSON.parse(localStorage.getItem(MATCH_BTN_POS_KEY)); } catch (e) {}
  if (pos && typeof pos.right === 'number' && typeof pos.top === 'number') {
    btn.style.right = pos.right + 'px';
    btn.style.left = 'auto';
    btn.style.top = pos.top + 'px';
  }
  // sem posição salva: usa o right/top do CSS padrão (canto superior direito da viewport)
}

function makeMatchBtnDraggable(btn) {
  let dragging = false, moved = false, startX = 0, startY = 0, startLeft = 0, startTop = 0;
  const size = () => btn.getBoundingClientRect();

  function toLeftTop() {
    const r = size();
    btn.style.left = r.left + 'px';
    btn.style.top = r.top + 'px';
    btn.style.right = 'auto';
  }
  function onDown(x, y) {
    toLeftTop();
    const r = size();
    dragging = true; moved = false;
    startX = x; startY = y; startLeft = r.left; startTop = r.top;
    btn.classList.add('dragging');
  }
  function onMove(x, y) {
    if (!dragging) return;
    const dx = x - startX, dy = y - startY;
    if (Math.abs(dx) > 4 || Math.abs(dy) > 4) moved = true;
    let left = startLeft + dx, top = startTop + dy;
    const r = size();
    left = Math.max(4, Math.min(window.innerWidth - r.width - 4, left));
    top  = Math.max(4, Math.min(window.innerHeight - r.height - 4, top));
    btn.style.left = left + 'px';
    btn.style.top = top + 'px';
  }
  function onUp() {
    if (!dragging) return;
    dragging = false;
    btn.classList.remove('dragging');
    if (moved) {
      const r = size();
      const rightPx = window.innerWidth - r.right;
      try { localStorage.setItem(MATCH_BTN_POS_KEY, JSON.stringify({ right: rightPx, top: r.top })); } catch (e) {}
    }
  }
  function onClick(e) {
    if (moved) { e.preventDefault(); moved = false; }
  }

  btn.addEventListener('mousedown', e => { onDown(e.clientX, e.clientY); e.preventDefault(); });
  window.addEventListener('mousemove', e => onMove(e.clientX, e.clientY));
  window.addEventListener('mouseup', onUp);
  btn.addEventListener('touchstart', e => { const t = e.touches[0]; onDown(t.clientX, t.clientY); }, {passive:true});
  btn.addEventListener('touchmove', e => { const t = e.touches[0]; onMove(t.clientX, t.clientY); }, {passive:true});
  btn.addEventListener('touchend', onUp);
  btn.addEventListener('click', onClick);
}

function swTab(name, btn) {
  document.querySelectorAll('#adminTabs .atab').forEach(t => t.classList.remove('on'));
  document.querySelectorAll('.apane').forEach(t => t.classList.remove('on'));
  btn.classList.add('on');
  document.getElementById('tab-' + name).classList.add('on');
  if (name === 'manage')   renderAdminList();
  if (name === 'overview') renderOverviewTab();
}

function renderAdminList() {
  const alist = document.getElementById('alist');

  // Cabeçalho com checkboxes "selecionar todos"
  const allAvail = products.length > 0 && products.every(p => p.status === 'available');
  const allFav   = products.length > 0 && products.every(p => p.favorite);
  const allNew   = products.length > 0 && products.every(p => p.isNew);

  const chkStyle = 'width:16px;height:16px;cursor:pointer;appearance:none;-webkit-appearance:none;border:1.5px solid #653C2B;border-radius:3px;flex-shrink:0;transition:background .2s,border-color .2s;';

  const header = `
    <div style="display:flex;align-items:stretch;border-bottom:2px solid var(--rose);background:var(--bg);">
      <div class="alist-name" style="width:340px;min-width:340px;flex-shrink:0;box-sizing:border-box;"></div>
      <div class="alist-btns alist-btns-hdr" style="overflow-x:auto;flex:1;min-width:0;-ms-overflow-style:none;scrollbar-width:none;display:flex;align-items:center;">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:6px;padding:6px 14px 6px 6px;width:100%;min-width:max-content;">
          <div style="width:94px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <input type="checkbox" id="chkAllAvail" ${allAvail?'checked':''} title="Selecionar todos como disponível"
              onchange="bulkSetStatus(this.checked ? 'available' : 'sold_out')"
              style="${chkStyle}background:${allAvail?'#8B4A3C':'#F3EFE9'};border-color:${allAvail?'#8B4A3C':'#653C2B'};">
          </div>
          <div style="width:38px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <input type="checkbox" id="chkAllPromo" title="Gerenciar promoções em massa"
              onclick="openBulkPromoModal(this);return false;"
              style="${chkStyle}background:#B34545;border-color:#B34545;">
          </div>
          <div style="width:38px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <input type="checkbox" id="chkAllFav" ${allFav?'checked':''} title="Selecionar todos como favorito"
              onchange="bulkToggle('favorite',this.checked)"
              style="${chkStyle}background:${allFav?'#8B4A3C':'#F3EFE9'};border-color:${allFav?'#8B4A3C':'#653C2B'};">
          </div>
          <div style="width:64px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <input type="checkbox" id="chkAllNew" ${allNew?'checked':''} title="Selecionar todos como Novo"
              onchange="bulkToggle('isNew',this.checked)"
              style="${chkStyle}background:${allNew?'#8B4A3C':'#F3EFE9'};border-color:${allNew?'#8B4A3C':'#653C2B'};">
          </div>
          <div style="width:72px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <input type="checkbox" id="chkAllDel" title="Excluir todos os itens"
              onclick="bulkDeleteAll(this);return false;"
              style="${chkStyle}background:#B34545;border-color:#B34545;">
          </div>
        </div>
      </div>
    </div>`;

  const rows = products.map((p, i) => {
    const bg = i % 2 === 0 ? 'rgba(243,239,233,.55)' : 'rgba(182,139,115,.06)';
    return `
    <div style="display:flex;align-items:stretch;background:${bg};border-bottom:1px solid var(--line);">
      <div class="alist-name" id="aname-${p.id}"
        style="font-family:'Cormorant Garamond',serif;font-size:26px;color:var(--text);
               line-height:1.25;overflow:hidden;white-space:nowrap;
               text-overflow:ellipsis;flex-shrink:0;
               width:340px;min-width:340px;
               padding:10px 8px 10px 12px;box-sizing:border-box;align-self:center;"
        title="${p.name}">${p.name}</div>
      <div class="alist-btns" style="overflow-x:auto;flex:1;min-width:0;
           -ms-overflow-style:none;scrollbar-width:none;display:flex;align-items:center;">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:6px;padding:10px 14px 10px 6px;width:100%;min-width:max-content;">
          <button onclick="togAvail(${p.id})" title="Clique para alternar o status"
            style="height:29px;min-width:94px;padding:0 6px;flex-shrink:0;cursor:pointer;transition:all .3s;
                   font-size:clamp(8px,2.4vw,9.6px);letter-spacing:.1em;font-family:'Jost',sans-serif;font-weight:600;
                   white-space:nowrap;box-sizing:border-box;
                   ${statusBtnCss(p.status)}">
            ${STATUS_LABEL[p.status]}
          </button>
          <button class="aabtn" onclick="openPriceModal(${p.id})"
            style="font-size:16px;padding:0;width:38px;height:38px;display:flex;align-items:center;
                   justify-content:center;flex-shrink:0;border:1px solid var(--rose);
                   background:rgba(139,74,60,.06);color:#8B4A3C;cursor:pointer;">$</button>
          <button class="aabtn" onclick="togFav(${p.id})"
            style="font-size:18px;padding:0;width:38px;height:38px;display:flex;align-items:center;
                   justify-content:center;flex-shrink:0;
                   border:1px solid ${p.favorite ? '#f5c518' : 'var(--line)'};
                   background:${p.favorite ? 'rgba(245,197,24,.12)' : 'transparent'};
                   color:${p.favorite ? '#f5c518' : '#C0B4AB'};">${p.favorite ? '★' : '☆'}</button>
          <button class="aabtn" onclick="togNew(${p.id})"
            style="font-size:9px;padding:0;width:64px;height:38px;display:flex;align-items:center;
                   justify-content:center;flex-shrink:0;letter-spacing:.1em;
                   border:1px solid ${p.isNew ? '#2196a8' : 'var(--line)'};
                   background:${p.isNew ? 'rgba(33,150,168,.1)' : 'transparent'};
                   color:${p.isNew ? '#2196a8' : '#C0B4AB'};">${p.isNew ? 'NOVO ✓' : 'NOVO'}</button>
          <button class="aabtn del" onclick="confirmDel(${p.id})"
            style="width:72px;height:38px;padding:0;display:flex;align-items:center;
                   justify-content:center;flex-shrink:0;border-color:#b83232;color:#b83232;">Remover</button>
        </div>
      </div>
    </div>`;
  }).join('');

  alist.innerHTML = `<div id="alist-inner">${header}${rows}</div>`;

  // Scroll: sincroniza todas as linhas (incluindo header) + reduz/restaura nome
  const allBtnsEls = alist.querySelectorAll('.alist-btns');
  const allNamesEls = alist.querySelectorAll('.alist-name');
  const FULL = 340, HALF = 170;

  function applyNameWidth(sl) {
    const collapsed = sl > 4;
    allNamesEls.forEach(n => {
      n.style.width    = (collapsed ? HALF : FULL) + 'px';
      n.style.minWidth = (collapsed ? HALF : FULL) + 'px';
    });
  }

  let syncing = false;
  allBtnsEls.forEach(el => {
    el.addEventListener('scroll', function() {
      if (syncing) return;
      syncing = true;
      const sl = this.scrollLeft;
      allBtnsEls.forEach(other => { other.scrollLeft = sl; });
      applyNameWidth(sl);
      syncing = false;
    }, {passive:true});
  });
}

function showToast(msg) {
  const t = document.createElement('div');
  t.style.cssText = 'position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:#2A1F18;color:#fff;padding:10px 20px;border-radius:8px;font-size:12px;font-family:"Jost",sans-serif;z-index:9999;opacity:0;transition:opacity .3s;white-space:nowrap;';
  t.textContent = msg;
  document.body.appendChild(t);
  requestAnimationFrame(() => { t.style.opacity = '1'; });
  setTimeout(() => { t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 2500);
}

function openBulkPromoModal(chk) {
  chk.checked = false;
  const hasPromo = products.some(p => p.promo);
  const wrap = document.createElement('div');
  wrap.id = 'bulkPromoModal';
  wrap.style.cssText = 'position:fixed;inset:0;z-index:9450;background:rgba(42,31,24,.7);display:flex;align-items:center;justify-content:center;';
  wrap.innerHTML = `
    <div style="background:var(--bg);border-radius:12px;padding:28px 28px;max-width:340px;width:90%;font-family:'Jost',sans-serif;">
      <p style="font-size:14px;font-weight:700;color:#2A1F18;margin-bottom:4px;">Promoções em Massa</p>
      <p style="font-size:11px;color:#A08070;margin-bottom:20px;">Escolha uma ação para aplicar a todos os itens.</p>

      <div style="border:1px solid var(--line);border-radius:8px;padding:14px;margin-bottom:14px;">
        <p style="font-size:11px;font-weight:600;color:#8B4A3C;letter-spacing:.08em;margin-bottom:10px;">APLICAR DESCONTO EM TODOS</p>
        <label style="font-size:10px;letter-spacing:.14em;color:#A08070;display:block;margin-bottom:4px;">PERCENTUAL DE DESCONTO</label>
        <div style="display:flex;align-items:stretch;margin-bottom:10px;">
          <input id="bulkPct" class="fi" placeholder="ex: 20" inputmode="decimal" style="border-radius:4px 0 0 4px;border-right:none;">
          <span style="display:flex;align-items:center;padding:0 12px;border:1px solid var(--line);background:#F2ECE6;color:var(--rose-dark);font-size:13px;font-weight:600;border-radius:0 4px 4px 0;">%</span>
        </div>
        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin-bottom:12px;">
          <input type="checkbox" id="bulkShowPct" checked style="accent-color:#8B4A3C;">
          <span style="font-size:11px;color:#A08070;">Mostrar percentual de desconto na bolsa</span>
        </label>
        <button onclick="applyBulkPromoPct()" style="width:100%;padding:10px;border:none;border-radius:6px;background:var(--rose-dark);color:#fff;cursor:pointer;font-size:12px;font-weight:700;">Aplicar a Todos</button>
      </div>

      <div style="border:1px solid var(--line);border-radius:8px;padding:14px;margin-bottom:18px;">
        <p style="font-size:11px;font-weight:600;color:#b83232;letter-spacing:.08em;margin-bottom:10px;">REMOVER TODAS AS PROMOÇÕES</p>
        <p style="font-size:11px;color:#A08070;margin-bottom:12px;">${hasPromo ? `${products.filter(p=>p.promo).length} item(s) com promoção ativa.` : 'Nenhum item tem promoção ativa.'}</p>
        <button onclick="removeAllPromos()" ${hasPromo ? '' : 'disabled'} style="width:100%;padding:10px;border:none;border-radius:6px;background:${hasPromo?'#b83232':'#D9CFC6'};color:#fff;cursor:${hasPromo?'pointer':'not-allowed'};font-size:12px;font-weight:700;">Remover Todas</button>
      </div>

      <p id="bulkPromoErr" style="font-size:11px;color:#b83232;margin-bottom:10px;display:none;"></p>

      <div style="display:flex;justify-content:flex-end;">
        <button onclick="document.getElementById('bulkPromoModal').remove()" style="padding:10px 20px;border:1px solid var(--line);background:none;cursor:pointer;font-size:12px;color:#A08070;">Fechar</button>
      </div>
    </div>`;
  document.body.appendChild(wrap);
}

function applyBulkPromoPct() {
  const errEl = document.getElementById('bulkPromoErr');
  const pctStr = document.getElementById('bulkPct').value.trim();
  const pct = parseFloat(pctStr.replace(',', '.'));
  if (!pctStr || isNaN(pct) || pct <= 0 || pct >= 100) {
    errEl.textContent = 'Informe um percentual válido entre 1 e 99.';
    errEl.style.display = 'block';
    return;
  }
  const showPct = document.getElementById('bulkShowPct').checked;
  showConfirmDouble(
    `Aplicar ${pct}% de desconto a todos?`,
    `${products.length} item(s) terão o preço atual usado como base para o desconto.`,
    'Tem certeza? Promoções existentes serão substituídas.',
    () => {
      products.forEach(p => {
        const base = p.promo ? parsePrice(p.promo.old) : parsePrice(p.price);
        const baseNum = p.promo ? priceNum(p.promo.old) : priceNum(p.price);
        const newVal = (base * (1 - pct / 100));
        const newNum = (Math.round(newVal * 100) / 100).toFixed(0);
        p.promo = { old: toPriceStr(baseNum), new: toPriceStr(newNum), pct: Math.round(pct), showPct };
        p.price = toPriceStr(newNum);
      });
      markDirty(); renderProducts('all'); renderAdminList(); renderOverviewTab();
      const m = document.getElementById('bulkPromoModal'); if (m) m.remove();
      showToast(`Desconto de ${pct}% aplicado a todos os itens.`);
    }
  );
}

function removeAllPromos() {
  const hasPromo = products.some(p => p.promo);
  if (!hasPromo) { showToast('Nenhum item tem promoção ativa.'); return; }
  showConfirmDouble(
    'Remover todas as promoções?',
    `${products.filter(p=>p.promo).length} item(s) têm promoção ativa.`,
    'Tem certeza? Esta ação não pode ser desfeita.',
    () => {
      products.forEach(p => { if (p.promo) { p.price = p.promo.new; p.promo = null; } });
      markDirty(); renderProducts('all'); renderAdminList(); renderOverviewTab();
      const m = document.getElementById('bulkPromoModal'); if (m) m.remove();
      showToast('Promoções removidas.');
    }
  );
}

function bulkDeleteAll(chk) {
  chk.checked = false;
  if (!products.length) { showToast('Catálogo já está vazio.'); return; }
  showConfirmDouble(
    'Excluir TODOS os itens?',
    `${products.length} item(s) serão removidos permanentemente.`,
    'Tem certeza absoluta? Esta ação é irreversível.',
    () => {
      products = [];
      markDirty(); renderProducts('all'); renderAdminList(); renderOverviewTab(); renderFavCarousel();
      showToast('Todos os itens foram excluídos.');
    }
  );
}

function showConfirmDouble(title, msg1, msg2, onConfirm) {
  // Primeira confirmação
  const w1 = document.createElement('div');
  w1.style.cssText = 'position:fixed;inset:0;z-index:9500;background:rgba(42,31,24,.7);display:flex;align-items:center;justify-content:center;';
  w1.innerHTML = `
    <div style="background:var(--bg);border-radius:12px;padding:28px 28px;max-width:320px;width:90%;font-family:'Jost',sans-serif;text-align:center;">
      <p style="font-size:14px;font-weight:700;color:#2A1F18;margin-bottom:8px;">${title}</p>
      <p style="font-size:12px;color:#A08070;margin-bottom:24px;">${msg1}</p>
      <div style="display:flex;gap:10px;justify-content:center;">
        <button onclick="this.closest('[style*=z-index]').remove()"
          style="padding:10px 22px;border:1px solid var(--line);background:none;cursor:pointer;font-size:12px;color:#A08070;border-radius:6px;">Cancelar</button>
        <button id="c1yes"
          style="padding:10px 22px;border:none;background:#b83232;color:#fff;cursor:pointer;font-size:12px;font-weight:700;border-radius:6px;">Sim, continuar</button>
      </div>
    </div>`;
  document.body.appendChild(w1);
  w1.querySelector('#c1yes').onclick = () => {
    w1.remove();
    // Segunda confirmação
    const w2 = document.createElement('div');
    w2.style.cssText = 'position:fixed;inset:0;z-index:9500;background:rgba(42,31,24,.75);display:flex;align-items:center;justify-content:center;';
    w2.innerHTML = `
      <div style="background:var(--bg);border-radius:12px;padding:28px 28px;max-width:320px;width:90%;font-family:'Jost',sans-serif;text-align:center;">
        <p style="font-size:14px;font-weight:700;color:#b83232;margin-bottom:8px;">⚠️ Confirmação final</p>
        <p style="font-size:12px;color:#A08070;margin-bottom:24px;">${msg2}</p>
        <div style="display:flex;gap:10px;justify-content:center;">
          <button onclick="this.closest('[style*=z-index]').remove()"
            style="padding:10px 22px;border:1px solid var(--line);background:none;cursor:pointer;font-size:12px;color:#A08070;border-radius:6px;">Não, voltar</button>
          <button id="c2yes"
            style="padding:10px 22px;border:none;background:#b83232;color:#fff;cursor:pointer;font-size:12px;font-weight:700;border-radius:6px;">Confirmar</button>
        </div>
      </div>`;
    document.body.appendChild(w2);
    w2.querySelector('#c2yes').onclick = () => { w2.remove(); onConfirm(); };
  };
}

function syncChk(el, active) {
  if (!el) return;
  el.checked = active;
  el.style.background  = active ? '#8B4A3C' : '#F3EFE9';
  el.style.borderColor = active ? '#8B4A3C' : '#653C2B';
}

function syncAllChk() {
  syncChk(document.getElementById('chkAllAvail'), products.length > 0 && products.every(p => p.status === 'available'));
  syncChk(document.getElementById('chkAllFav'),   products.length > 0 && products.every(p => p.favorite));
  syncChk(document.getElementById('chkAllNew'),   products.length > 0 && products.every(p => p.isNew));
}

function bulkSetStatus(status) {
  products.forEach(p => { p.status = status; });
  markDirty();
  renderProducts('all');
  renderFavCarousel();
  renderOverviewTab();
  products.forEach(p => {
    const btn = document.querySelector(`button[onclick="togAvail(${p.id})"]`);
    if (btn) {
      btn.textContent = STATUS_LABEL[p.status];
      btn.style.cssText = `height:29px;min-width:94px;padding:0 6px;flex-shrink:0;cursor:pointer;transition:all .3s;font-size:clamp(8px,2.4vw,9.6px);letter-spacing:.1em;font-family:'Jost',sans-serif;font-weight:600;white-space:nowrap;box-sizing:border-box;${statusBtnCss(p.status)}`;
    }
  });
  syncAllChk();
}

function bulkToggle(field, value) {
  products.forEach(p => { p[field] = value; });
  markDirty();
  renderProducts('all');
  renderFavCarousel();
  renderOverviewTab();

  // Atualiza cada botão no DOM sem recriar a lista (evita reset do scroll/largura)
  products.forEach(p => {
    if (field === 'favorite') {
      const btn = document.querySelector(`button[onclick="togFav(${p.id})"]`);
      if (btn) {
        btn.textContent = p.favorite ? '★' : '☆';
        btn.style.cssText = `font-size:18px;padding:0;width:38px;height:38px;display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid ${p.favorite ? '#f5c518' : 'var(--line)'};background:${p.favorite ? 'rgba(245,197,24,.12)' : 'transparent'};color:${p.favorite ? '#f5c518' : '#C0B4AB'};cursor:pointer;`;
      }
    }
    if (field === 'isNew') {
      const btn = document.querySelector(`button[onclick="togNew(${p.id})"]`);
      if (btn) {
        btn.textContent = p.isNew ? 'NOVO ✓' : 'NOVO';
        btn.style.cssText = `font-size:9px;padding:0;width:64px;height:38px;display:flex;align-items:center;justify-content:center;flex-shrink:0;letter-spacing:.1em;border:1px solid ${p.isNew ? '#2196a8' : 'var(--line)'};background:${p.isNew ? 'rgba(33,150,168,.1)' : 'transparent'};color:${p.isNew ? '#2196a8' : '#C0B4AB'};cursor:pointer;`;
      }
    }
  });

  // Atualiza estado do checkbox do cabeçalho
  syncAllChk();
}

// ─── BANNER: TROCAR IMAGEM ─────────────────────────────────────────────────────
function triggerBannerUpload(idx) {
  const input = document.getElementById('bannerFile-' + idx);
  if (input) input.click();
}
function handleBannerUpload(idx, input) {
  const file = input.files && input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    const dataUrl = e.target.result;
    HERO_SLIDES[idx] = dataUrl;
    const thumb = document.getElementById('bannerImg-' + idx);
    if (thumb) thumb.src = dataUrl;
    const slideBg = document.getElementById('heroSlideImg-' + idx);
    if (slideBg) slideBg.style.backgroundImage = `url('${dataUrl}')`;
    markDirty();
    showToast(`Imagem do Slide ${idx + 1} atualizada.`);
  };
  reader.readAsDataURL(file);
}

function addProd() {
  const name  = document.getElementById('nn').value.trim();
  const price = document.getElementById('np').value.trim();
  const msg   = document.getElementById('addMsg');
  if (!name || !price) {
    msg.style.color = '#7A1E1E';
    msg.textContent = 'Preencha o nome e o preço.';
    return;
  }
  products.unshift({
    id: Date.now(), name, cat: document.getElementById('nc').value,
    price, status: document.getElementById('na').value,
    isNew: document.getElementById('nin').value === 'true',
    favorite: false
  });
  markDirty();
  renderProducts('all');
  document.querySelectorAll('.fpill').forEach(b => b.classList.remove('on'));
  document.querySelector('.fpill').classList.add('on');
  msg.style.color = '#1a7a3e';
  msg.textContent = `"${name}" adicionada com sucesso!`;
  document.getElementById('nn').value = '';
  document.getElementById('np').value = '';
}

function openPriceModal(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  const wrap = document.createElement('div');
  wrap.id = 'priceModal';
  wrap.style.cssText = 'position:fixed;inset:0;z-index:9400;background:rgba(42,31,24,.65);display:flex;align-items:center;justify-content:center;';
  wrap.innerHTML = `
    <div style="background:var(--bg);border-radius:12px;padding:28px 32px;max-width:360px;width:92%;font-family:'Jost',sans-serif;">
      <p style="font-size:14px;font-weight:700;color:#2A1F18;margin-bottom:4px;">Editar Preço</p>
      <p style="font-size:11px;color:#A08070;margin-bottom:20px;">${p.name}</p>

      <label style="font-size:10px;letter-spacing:.14em;color:#A08070;display:block;margin-bottom:6px;">PREÇO ATUAL</label>
      <div style="display:flex;align-items:stretch;margin-bottom:18px;">
        <span style="display:flex;align-items:center;padding:0 12px;border:1px solid var(--line);border-right:none;background:#F2ECE6;color:var(--rose-dark);font-size:13px;font-weight:600;border-radius:4px 0 0 4px;">R$</span>
        <input id="pmPrice" class="fi" value="${priceNum(p.price)}" placeholder="0" inputmode="decimal" style="border-radius:0 4px 4px 0;border-left:none;">
      </div>

      <div id="pmPromoWrap" style="border:1px solid var(--line);border-radius:8px;padding:14px;margin-bottom:18px;">
        <div style="display:flex;align-items:center;margin-bottom:10px;">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
            <input type="checkbox" id="pmPromoOn" ${p.promo ? 'checked' : ''} onchange="togglePromoFields()" style="accent-color:#8B4A3C;">
            <span style="font-size:11px;font-weight:600;color:#8B4A3C;letter-spacing:.1em;">ATIVAR PROMOÇÃO</span>
          </label>
        </div>
        <div id="pmPromoFields" style="display:${p.promo ? 'block' : 'none'};">
          <label style="font-size:10px;letter-spacing:.14em;color:#A08070;display:block;margin-bottom:4px;">PREÇO ORIGINAL (riscado)</label>
          <div style="display:flex;align-items:stretch;margin-bottom:10px;">
            <span style="display:flex;align-items:center;padding:0 12px;border:1px solid var(--line);border-right:none;background:#F2ECE6;color:#A08070;font-size:13px;font-weight:600;border-radius:4px 0 0 4px;">R$</span>
            <input id="pmOldPrice" class="fi" value="${priceNum(p.promo ? p.promo.old : p.price)}" placeholder="0" readonly style="border-radius:0 4px 4px 0;border-left:none;background:#F2ECE6;color:#A08070;cursor:not-allowed;">
          </div>
          <div style="display:flex;gap:10px;margin-bottom:10px;">
            <div style="flex:1;">
              <label style="font-size:10px;letter-spacing:.14em;color:#A08070;display:block;margin-bottom:4px;">PREÇO PROMOCIONAL</label>
              <div style="display:flex;align-items:stretch;">
                <span style="display:flex;align-items:center;padding:0 12px;border:1px solid var(--line);border-right:none;background:#F2ECE6;color:var(--rose-dark);font-size:13px;font-weight:600;border-radius:4px 0 0 4px;">R$</span>
                <input id="pmNewPrice" class="fi" value="${p.promo ? priceNum(p.promo.new) : ''}" placeholder="0" inputmode="decimal" oninput="syncFromPrice()" style="border-radius:0 4px 4px 0;border-left:none;">
              </div>
            </div>
            <div style="flex:1;">
              <label style="font-size:10px;letter-spacing:.14em;color:#A08070;display:block;margin-bottom:4px;">DESCONTO</label>
              <div style="display:flex;align-items:stretch;">
                <input id="pmPct" class="fi" value="${p.promo && p.promo.pct ? p.promo.pct : ''}" placeholder="0" inputmode="decimal" oninput="syncFromPct()" style="border-radius:4px 0 0 4px;border-right:none;">
                <span style="display:flex;align-items:center;padding:0 12px;border:1px solid var(--line);background:#F2ECE6;color:var(--rose-dark);font-size:13px;font-weight:600;border-radius:0 4px 4px 0;">%</span>
              </div>
            </div>
          </div>
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
            <input type="checkbox" id="pmShowPct" ${(!p.promo || p.promo.showPct !== false) ? 'checked' : ''} style="accent-color:#8B4A3C;">
            <span style="font-size:11px;color:#A08070;">Mostrar percentual de desconto na bolsa</span>
          </label>
        </div>
      </div>

      <p id="pmErr" style="font-size:11px;color:#b83232;margin-bottom:10px;display:none;"></p>

      <div style="display:flex;gap:10px;justify-content:flex-end;">
        <button onclick="document.getElementById('priceModal').remove()" style="padding:10px 20px;border:1px solid var(--line);background:none;cursor:pointer;font-size:12px;color:#A08070;">Cancelar</button>
        <button onclick="savePrice(${id})" style="padding:10px 20px;border:none;background:var(--rose-dark);color:#fff;cursor:pointer;font-size:12px;font-weight:700;">Salvar</button>
      </div>
    </div>`;
  document.body.appendChild(wrap);
}

function priceNum(str) {
  return (str || '').replace(/^R\$\s*/i, '').trim();
}

function toPriceStr(num) {
  return `R$ ${num}`;
}

function togglePromoFields() {
  const on = document.getElementById('pmPromoOn').checked;
  document.getElementById('pmPromoFields').style.display = on ? 'block' : 'none';
  if (on) {
    const oldEl = document.getElementById('pmOldPrice');
    if (!oldEl.value) oldEl.value = document.getElementById('pmPrice').value.trim();
  }
}

function syncFromPrice() {
  const oldNum = parsePrice(document.getElementById('pmOldPrice').value);
  const newNum = parsePrice(document.getElementById('pmNewPrice').value);
  const pctEl = document.getElementById('pmPct');
  if (oldNum > 0 && document.getElementById('pmNewPrice').value.trim() !== '') {
    const pct = (1 - newNum / oldNum) * 100;
    pctEl.value = Math.round(pct * 10) / 10;
  } else {
    pctEl.value = '';
  }
}

function syncFromPct() {
  const oldNum = parsePrice(document.getElementById('pmOldPrice').value);
  const pctVal = parseFloat(document.getElementById('pmPct').value.replace(',', '.'));
  const newEl = document.getElementById('pmNewPrice');
  if (oldNum > 0 && !isNaN(pctVal)) {
    const newVal = oldNum * (1 - pctVal / 100);
    newEl.value = (Math.round(newVal * 100) / 100).toFixed(newVal % 1 === 0 ? 0 : 2);
  } else {
    newEl.value = '';
  }
}

function parsePrice(str) {
  return parseFloat(String(str).replace(/[^\d,\.]/g,'').replace(',','.')) || 0;
}

function savePrice(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  const errEl = document.getElementById('pmErr');
  const newPriceNum = document.getElementById('pmPrice').value.trim();
  const promoOn  = document.getElementById('pmPromoOn').checked;

  if (promoOn) {
    const oldNum = document.getElementById('pmOldPrice').value.trim();
    const newNum = document.getElementById('pmNewPrice').value.trim();
    if (!oldNum || !newNum) { errEl.textContent='Preencha os dois preços da promoção.'; errEl.style.display='block'; return; }
    if (parsePrice(newNum) >= parsePrice(oldNum)) {
      errEl.textContent='O preço promocional deve ser menor que o preço original.';
      errEl.style.display='block'; return;
    }
    const pct = Math.round((1 - parsePrice(newNum) / parsePrice(oldNum)) * 100);
    const showPct = document.getElementById('pmShowPct').checked;
    p.promo = { old: toPriceStr(oldNum), new: toPriceStr(newNum), pct, showPct };
    p.price = toPriceStr(newNum);
  } else {
    p.promo = null;
    if (newPriceNum) p.price = toPriceStr(newPriceNum);
  }
  markDirty();
  renderProducts('all');
  renderOverviewTab();
  document.getElementById('priceModal').remove();
}

function togAvail(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  p.status = nextStatus(p.status);
  markDirty();
  renderProducts('all');
  updateAdminRow(id);
}

function confirmDel(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  const wrap = document.createElement('div');
  wrap.style.cssText = 'position:fixed;inset:0;z-index:9300;background:rgba(42,31,24,.65);display:flex;align-items:center;justify-content:center;';
  wrap.innerHTML = `<div style="background:#fff;border-radius:12px;padding:28px 32px;max-width:340px;text-align:center;">
    <p style="font-size:14px;font-weight:700;color:#2A1F18;margin-bottom:6px;">Remover bolsa?</p>
    <p style="font-size:12px;color:#A08070;margin-bottom:22px;">"${p.name}" será removida do catálogo.</p>
    <div style="display:flex;gap:10px;justify-content:center;">
      <button id="delNo"  style="padding:10px 22px;border:1px solid #D4C5BA;border-radius:8px;background:none;cursor:pointer;font-size:12px;">Não, cancelar</button>
      <button id="delYes" style="padding:10px 22px;border:none;border-radius:8px;background:#b83232;color:#fff;cursor:pointer;font-size:12px;font-weight:700;">Sim, remover</button>
    </div>
  </div>`;
  document.body.appendChild(wrap);
  wrap.querySelector('#delNo').onclick  = () => wrap.remove();
  wrap.querySelector('#delYes').onclick = () => { wrap.remove(); delProd(id); };
}

function delProd(id) {
  products = products.filter(x => x.id !== id);
  markDirty(); renderProducts('all'); renderAdminList(); renderOverviewTab();
}

function togNew(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  p.isNew = !p.isNew;
  markDirty();
  renderProducts('all');
  updateAdminRow(id);
}

function togFav(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  p.favorite = !p.favorite;
  markDirty();
  renderFavCarousel();
  updateAdminRow(id);
}

// Update a single admin row without re-rendering the entire list
function updateAdminRow(id) {
  renderOverviewTab();
  const p = products.find(x => x.id === id);
  if (!p) return;

  // Na nova estrutura, cada linha é uma div filha direta de #alist-inner
  // Os botões têm onclick="togXxx(ID)" — buscamos por onclick exato
  const availBtn = document.querySelector(`button[onclick="togAvail(${id})"]`);
  if (availBtn) {
    availBtn.textContent = STATUS_LABEL[p.status];
    availBtn.style.cssText = `height:29px;min-width:94px;padding:0 6px;flex-shrink:0;cursor:pointer;transition:all .3s;font-size:clamp(8px,2.4vw,9.6px);letter-spacing:.1em;font-family:'Jost',sans-serif;font-weight:600;white-space:nowrap;box-sizing:border-box;${statusBtnCss(p.status)}`;
    availBtn.title = 'Clique para alternar o status';
  }

  const favBtn = document.querySelector(`button[onclick="togFav(${id})"]`);
  if (favBtn) {
    favBtn.textContent = p.favorite ? '★' : '☆';
    favBtn.style.cssText = `font-size:18px;padding:0;width:38px;height:38px;display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid ${p.favorite ? '#f5c518' : 'var(--line)'};background:${p.favorite ? 'rgba(245,197,24,.12)' : 'transparent'};color:${p.favorite ? '#f5c518' : '#C0B4AB'};cursor:pointer;`;
    favBtn.title = p.favorite ? 'Remover dos favoritos' : 'Adicionar aos favoritos';
  }

  const newBtn = document.querySelector(`button[onclick="togNew(${id})"]`);
  if (newBtn) {
    newBtn.textContent = p.isNew ? 'NOVO ✓' : 'NOVO';
    newBtn.style.cssText = `font-size:9px;padding:0;width:64px;height:38px;display:flex;align-items:center;justify-content:center;flex-shrink:0;letter-spacing:.1em;border:1px solid ${p.isNew ? '#2196a8' : 'var(--line)'};background:${p.isNew ? 'rgba(33,150,168,.1)' : 'transparent'};color:${p.isNew ? '#2196a8' : '#C0B4AB'};cursor:pointer;`;
    newBtn.title = p.isNew ? 'Remover badge Novo' : 'Adicionar badge Novo';
  }

  // Sincroniza checkboxes do cabeçalho
  syncAllChk();
}

// ─── FAVORITES BANNER CAROUSEL ────────────────────────────────────────────────
let favIdx = 0;
let favTimer = null;

function renderFavCarousel() {
  const favs = products.filter(p => p.favorite && p.status === 'available');
  const wrap  = document.getElementById('favBannerWrap');
  const empty = document.getElementById('favEmpty');
  if (!wrap) return;

  if (favs.length === 0) {
    wrap.style.display  = 'none';
    if (empty) empty.style.display = 'block';
    clearInterval(favTimer);
    return;
  }
  wrap.style.display  = 'block';
  if (empty) empty.style.display = 'none';

  favIdx = 0;
  showFavSlide(favs);

  clearInterval(favTimer);
  favTimer = setInterval(() => {
    favIdx = (favIdx + 1) % favs.length;
    showFavSlide(favs);
  }, 3000);
}

function showFavSlide(favs) {
  const banner = document.getElementById('favBanner');
  if (!banner) return;
  const p = favs[favIdx];

  banner.innerHTML = `
    <div onclick="openBagModal(${p.id},'fav')" class="fav-slide-fade" style="width:100%;aspect-ratio:16/9;overflow:hidden;position:relative;cursor:pointer;border-radius:12px;">
      ${p.img
        ? `<img src="${p.img}" alt="${p.name}" style="width:100%;height:100%;object-fit:cover;transition:opacity .4s ease;">`
        : `<div style="width:100%;height:100%;background:var(--bg2);display:flex;align-items:center;justify-content:center;">
             <svg viewBox="0 0 200 220" width="80" fill="none"><path d="M58 84Q58 54 100 54Q142 54 142 84" stroke="#B68B73" stroke-width="3" fill="none"/><rect x="28" y="84" width="144" height="112" rx="8" fill="none" stroke="#B68B73" stroke-width="2.5"/></svg>
           </div>`}
      <div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(42,31,24,.7));padding:24px 20px 16px;pointer-events:none;">
        <div style="color:#fff;font-size:15px;font-weight:700;">${p.name}</div>
        <div style="color:#f5c9ad;font-size:13px;font-weight:600;">${p.price}</div>
      </div>
      <div style="position:absolute;top:14px;right:14px;background:rgba(255,255,255,.9);border-radius:20px;padding:4px 12px;font-size:10px;letter-spacing:.1em;font-weight:600;color:#8B4A3C;pointer-events:none;">Toque para ver</div>
    </div>
    <div style="display:flex;justify-content:center;gap:6px;margin-top:12px;">
      ${favs.map((_,i) => `<span onclick="jumpFav(${i})" style="width:${i===favIdx?'20px':'6px'};height:6px;border-radius:4px;background:${i===favIdx?'var(--rose-deep)':'var(--line)'};cursor:pointer;transition:width .3s,background .3s;display:inline-block;"></span>`).join('')}
    </div>`;
}

function favSlide(dir) {
  const favs = products.filter(p => p.favorite && p.status === 'available');
  if (!favs.length) return;
  favIdx = (favIdx + dir + favs.length) % favs.length;
  showFavSlide(favs);
  clearInterval(favTimer);
  favTimer = setInterval(() => {
    favIdx = (favIdx + 1) % favs.length;
    showFavSlide(favs);
  }, 3000);
}

function jumpFav(i) {
  const favs = products.filter(p => p.favorite && p.status === 'available');
  if (!favs.length) return;
  favIdx = i;
  showFavSlide(favs);
  clearInterval(favTimer);
  favTimer = setInterval(() => {
    favIdx = (favIdx + 1) % favs.length;
    showFavSlide(favs);
  }, 3000);
}

// ─── ANALYTICS ────────────────────────────────────────────────────────────────
const analytics = { views: {}, wa: {} }; // {id: {catalog:[ts,...], fav:[ts,...]}} / {id:[ts,...]}

function trackView(id, source) {
  if (!analytics.views[id]) analytics.views[id] = {catalog:[], fav:[]};
  if (!Array.isArray(analytics.views[id][source])) analytics.views[id][source] = [];
  analytics.views[id][source].push(Date.now());
}
function trackWa(id) {
  if (!Array.isArray(analytics.wa[id])) analytics.wa[id] = [];
  analytics.wa[id].push(Date.now());
}

// ─── BAG DETAIL MODAL ─────────────────────────────────────────────────────────
function openBagModal(id, source) {
  source = source || 'catalog';
  trackView(id, source);
  const p = products.find(x => x.id === id);
  if (!p) return;
  document.getElementById('modalPhoto').src = p.img || '';
  document.getElementById('modalPhoto').style.display = p.img ? 'block' : 'none';
  document.getElementById('modalName').textContent  = p.name;
  document.getElementById('modalCat').textContent   = CATS[p.cat] || '';
  document.getElementById('modalPrice').innerHTML = (p.promo)
    ? `<span style="text-decoration:line-through;color:#B5544A;font-size:15px;margin-right:8px;font-weight:600;">${p.promo.old}</span><span style="color:var(--rose-dark);">${p.promo.new}</span>${(p.promo.showPct && p.promo.pct) ? `<span style="display:inline-block;margin-left:10px;vertical-align:middle;background:#B5544A;color:#fff;font-size:11px;font-weight:700;font-family:'Jost',sans-serif;letter-spacing:.04em;padding:3px 8px;border-radius:3px;">-${p.promo.pct}%</span>` : ''}`
    : p.price;
  document.getElementById('modalWa').href = waMsg(p.name, p.status);
  document.getElementById('modalWa').onclick = () => trackWa(id);
  const m = document.getElementById('bagModal');
  m.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function closeBagModal() {
  document.getElementById('bagModal').style.display = 'none';
  document.body.style.overflow = '';
  const ph = document.getElementById('modalPhoto');
  if (ph) { ph.style.transform='scale(1)'; ph.dataset.zoom='0'; ph.parentElement.style.cursor='zoom-in'; }
}
// close modal on backdrop click — uses event delegation so bagModal doesn't need to exist yet
document.addEventListener('click', function(e) {
  if (e.target && e.target.id === 'bagModal') closeBagModal();
});

// ─── ADMIN SAVE / REVIEW ──────────────────────────────────────────────────────
let adminDirty   = false;   // tracks unsaved changes
let pendingSave  = null;    // snapshot of changes to save

function markDirty() { adminDirty = true; }

function openReview() {
  const favs   = products.filter(p => p.favorite);
  const avail  = products.filter(p => p.status === 'available');
  const esgot  = products.filter(p => p.status === 'sold_out');
  const embreve = products.filter(p => p.status === 'coming_soon');

  document.getElementById('reviewBody').innerHTML = `
    <div style="background:#faf7f4;border-radius:8px;padding:16px 18px;margin-bottom:14px;">
      <p style="font-weight:700;margin-bottom:8px;color:#2A1F18;">📦 Catálogo</p>
      <p>Total de bolsas: <strong>${products.length}</strong></p>
      <p>Disponíveis: <strong style="color:#1a7a3e;">${avail.length}</strong></p>
      <p>Esgotadas: <strong style="color:#7A1E1E;">${esgot.length}</strong></p>
      <p>Em Breve: <strong style="color:#C97A3D;">${embreve.length}</strong></p>
    </div>
    <div style="background:#faf7f4;border-radius:8px;padding:16px 18px;margin-bottom:14px;">
      <p style="font-weight:700;margin-bottom:8px;color:#2A1F18;">★ Favoritas do Momento</p>
      ${favs.length
        ? favs.map(p => `<p>· ${p.name} <span style="color:#A08070;">(${p.price})</span></p>`).join('')
        : `<p style="color:#A08070;">Nenhuma bolsa marcada como favorita.</p>`}
    </div>
    <div style="background:#faf7f4;border-radius:8px;padding:16px 18px;">
      <p style="font-weight:700;margin-bottom:8px;color:#2A1F18;">🆕 Bolsas com badge "Novo"</p>
      ${products.filter(p => p.isNew).length
        ? products.filter(p => p.isNew).map(p => `<p>· ${p.name}</p>`).join('')
        : `<p style="color:#A08070;">Nenhuma.</p>`}
    </div>`;

  const m = document.getElementById('reviewModal');
  m.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeReview() {
  document.getElementById('reviewModal').style.display = 'none';
  document.body.style.overflow = '';
}

function confirmSave() {
  adminDirty = false;
  closeReview();
  renderProducts('all');
  renderFavCarousel();
  _origCloseA(); // close admin panel
  const msg = document.createElement('div');
  msg.textContent = '✓ Configurações salvas com sucesso!';
  msg.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(.96);background:#e8f5e9;color:#2d6a4f;border:1px solid #b7dfc8;padding:18px 36px;border-radius:10px;font-size:13px;font-weight:600;z-index:9999;box-shadow:0 8px 32px rgba(0,0,0,.12);letter-spacing:.04em;opacity:0;transition:opacity .35s ease,transform .35s ease;';
  document.body.appendChild(msg);
  requestAnimationFrame(() => { msg.style.opacity = '1'; msg.style.transform = 'translate(-50%,-50%) scale(1)'; });
  setTimeout(() => {
    msg.style.opacity = '0';
    msg.style.transform = 'translate(-50%,-50%) scale(.96)';
    setTimeout(() => msg.remove(), 350);
  }, 2600);
}

// Intercept admin close — warn if dirty
const _origCloseA = closeA;
closeA = function() {
  if (adminDirty) {
    const wrap = document.createElement('div');
    wrap.style.cssText = 'position:fixed;inset:0;z-index:9200;background:rgba(42,31,24,.6);display:flex;align-items:center;justify-content:center;';
    wrap.innerHTML = `<div style="background:#fff;border-radius:12px;padding:32px;max-width:340px;text-align:center;">
      <p style="font-size:15px;font-weight:700;color:#2A1F18;margin-bottom:8px;">Alterações não salvas</p>
      <p style="font-size:12px;color:#A08070;margin-bottom:24px;">Você fez alterações no painel. Deseja salvar antes de sair?</p>
      <div style="display:flex;gap:10px;justify-content:center;">
        <button id="btnDiscardExit" style="padding:10px 18px;border:1px solid #D4C5BA;border-radius:8px;background:none;cursor:pointer;font-size:12px;">Sair sem salvar</button>
        <button id="btnSaveExit"    style="padding:10px 18px;border:none;border-radius:8px;background:#8B4A3C;color:#fff;cursor:pointer;font-size:12px;font-weight:700;">Revisar e Salvar</button>
      </div>
    </div>`;
    document.body.appendChild(wrap);
    document.getElementById('btnDiscardExit').onclick = () => { adminDirty=false; wrap.remove(); _origCloseA(); };
    document.getElementById('btnSaveExit').onclick    = () => { wrap.remove(); openReview(); };
  } else {
    _origCloseA();
  }
};

// ─── INIT ─────────────────────────────────────────────────────────────────────
renderProducts('all');
renderFavCarousel();
applyLooksButtonVisibility();
applyMatchButtonVisibility();
</script>

<!-- ═══ BAG DETAIL MODAL ════════════════════════════════════════════════════ -->
<div id="bagModal" style="display:none;position:fixed;inset:0;z-index:9000;background:rgba(42,31,24,.72);backdrop-filter:blur(6px);align-items:center;justify-content:center;">
  <div style="background:var(--bg);border-radius:16px;max-width:520px;width:92%;overflow:hidden;position:relative;animation:modalIn .28s ease;">
    <button onclick="closeBagModal()" style="position:absolute;top:14px;right:16px;background:none;border:none;font-size:22px;cursor:pointer;color:var(--text-muted);z-index:2;">✕</button>
    <div id="modalImgWrap" style="width:100%;aspect-ratio:1/1;overflow:hidden;background:var(--bg2);cursor:zoom-in;position:relative;touch-action:none;">
      <img id="modalPhoto" src="" alt="" style="width:100%;height:100%;object-fit:cover;transform-origin:center center;will-change:transform;">
    </div>
    <div style="padding:24px 28px 28px;background:var(--bg);">
      <div id="modalName"  style="font-size:18px;font-weight:700;color:#2A1F18;margin-bottom:6px;"></div>
      <div id="modalCat"   style="font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:#A08070;margin-bottom:16px;"></div>
      <div id="modalPrice" style="font-size:22px;font-weight:800;color:#8B4A3C;margin-bottom:20px;"></div>
      <a id="modalWa" href="#" target="_blank" class="pwa" style="text-decoration:none;width:fit-content;">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        Comprar via WhatsApp
      </a>
    </div>
  </div>
</div>
<style>
@keyframes modalIn { from{opacity:0;transform:scale(.94)} to{opacity:1;transform:scale(1)} }
</style>
<script>
(function(){
  let scale = 1, tx = 0, ty = 0;
  let lastDist = 0, dragging = false, lastX = 0, lastY = 0;

  function applyTransform(img, animated) {
    img.style.transition = animated ? 'transform .25s ease' : 'none';
    img.style.transform = `translate(${tx}px,${ty}px) scale(${scale})`;
  }

  function resetZoom(img, wrap) {
    scale = 1; tx = 0; ty = 0;
    applyTransform(img, true);
    wrap.style.cursor = 'zoom-in';
  }

  function clampTranslate(wrap) {
    const maxX = (wrap.offsetWidth  * (scale - 1)) / 2;
    const maxY = (wrap.offsetHeight * (scale - 1)) / 2;
    tx = Math.max(-maxX, Math.min(maxX, tx));
    ty = Math.max(-maxY, Math.min(maxY, ty));
  }

  document.getElementById('modalImgWrap').addEventListener('click', function(e) {
    if (e.target !== document.getElementById('modalPhoto')) return;
    const img = document.getElementById('modalPhoto');
    if (scale > 1) { resetZoom(img, this); return; }
    scale = 2.5; tx = 0; ty = 0;
    applyTransform(img, true);
    this.style.cursor = 'grab';
  });

  // Pinch zoom (touch)
  document.getElementById('modalImgWrap').addEventListener('touchstart', function(e) {
    if (e.touches.length === 2) {
      lastDist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
    } else if (e.touches.length === 1 && scale > 1) {
      dragging = true; lastX = e.touches[0].clientX; lastY = e.touches[0].clientY;
    }
  }, {passive:true});

  document.getElementById('modalImgWrap').addEventListener('touchmove', function(e) {
    const img = document.getElementById('modalPhoto');
    if (e.touches.length === 2) {
      e.preventDefault();
      const dist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
      scale = Math.max(1, Math.min(5, scale * (dist / lastDist)));
      lastDist = dist;
      clampTranslate(this);
      applyTransform(img, false);
      this.style.cursor = scale > 1 ? 'grab' : 'zoom-in';
    } else if (e.touches.length === 1 && dragging) {
      e.preventDefault();
      tx += e.touches[0].clientX - lastX;
      ty += e.touches[0].clientY - lastY;
      lastX = e.touches[0].clientX; lastY = e.touches[0].clientY;
      clampTranslate(this);
      applyTransform(img, false);
    }
  }, {passive:false});

  document.getElementById('modalImgWrap').addEventListener('touchend', function() {
    dragging = false;
    const img = document.getElementById('modalPhoto');
    if (scale < 1.05) resetZoom(img, this);
  });

  // Mouse drag
  document.getElementById('modalImgWrap').addEventListener('mousedown', function(e) {
    if (scale > 1) { dragging = true; lastX = e.clientX; lastY = e.clientY; this.style.cursor = 'grabbing'; }
  });
  document.addEventListener('mousemove', function(e) {
    if (!dragging) return;
    const wrap = document.getElementById('modalImgWrap');
    const img  = document.getElementById('modalPhoto');
    tx += e.clientX - lastX; ty += e.clientY - lastY;
    lastX = e.clientX; lastY = e.clientY;
    clampTranslate(wrap);
    applyTransform(img, false);
  });
  document.addEventListener('mouseup', function() {
    if (dragging) { dragging = false; const w = document.getElementById('modalImgWrap'); if(w) w.style.cursor = scale > 1 ? 'grab' : 'zoom-in'; }
  });

  // Reset ao fechar
  const origClose = window.closeBagModal;
  window.closeBagModal = function() {
    scale = 1; tx = 0; ty = 0;
    const img = document.getElementById('modalPhoto');
    if (img) { img.style.transform = ''; img.style.transition = ''; }
    origClose();
  };
})();
</script>

<!-- ═══ ADMIN REVIEW MODAL ══════════════════════════════════════════════════ -->
<div id="reviewModal" style="display:none;position:fixed;inset:0;z-index:9100;background:rgba(42,31,24,.75);backdrop-filter:blur(6px);align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:14px;max-width:480px;width:92%;max-height:80vh;overflow-y:auto;padding:32px;">
    <h3 style="font-size:15px;font-weight:700;color:#2A1F18;margin-bottom:4px;">Revisão das Configurações</h3>
    <p style="font-size:11px;color:#A08070;margin-bottom:24px;">Confira antes de salvar</p>
    <div id="reviewBody" style="font-size:12px;color:#4A3728;line-height:1.8;"></div>
    <div style="display:flex;gap:12px;margin-top:28px;">
      <button onclick="closeReview()" style="flex:1;padding:12px;border:1px solid #D4C5BA;border-radius:8px;background:none;cursor:pointer;font-size:12px;">Voltar e Editar</button>
      <button onclick="confirmSave()" style="flex:1;padding:12px;border:none;border-radius:8px;background:#8B4A3C;color:#fff;cursor:pointer;font-size:12px;font-weight:700;">✓ Confirmar e Salvar</button>
    </div>
  </div>
</div>
</body>
</html>
