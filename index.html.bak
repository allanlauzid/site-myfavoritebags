  </div>
</div>

<!-- ═══ ABOUT ══════════════════════════════════════════════════════════════════ -->
<section class="about" id="sobre">
  <div class="about-visual reveal">
    <!-- Large logo in about section --><img src="webp/LogoMFB_A.webp" alt="My Favorite Bags Recife" class="about-logo-img">
  </div>
  <div class="reveal reveal-d2">
